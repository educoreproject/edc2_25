    {
      "@id": "https://firsteducore.org/ontology#equity/open-badges-v3",
      "@type": "https://firsteducore.org/ontology#EquityConsideration",
      "https://firsteducore.org/ontology#level": "medium-concern",
      "https://firsteducore.org/ontology#notes": "Badge UX must be accessible across devices and literacy levels. Visual badge design should meet WCAG standards. Wallet/sharing UX can be a barrier for low-digital-literacy populations. Consider QR code and paper-friendly fallbacks.",
      "https://firsteducore.org/ontology#lifDerived": {
        "@value": "true",
        "@type": "xsd:boolean"
      }
    },
    {
      "@id": "https://firsteducore.org/ontology#privacy/open-badges-v3",
      "@type": "https://firsteducore.org/ontology#PrivacyConsideration",
      "https://firsteducore.org/ontology#level": "medium-concern",
      "https://firsteducore.org/ontology#notes": "Badges contain learner achievement data. Hosted badge verification can create tracking vectors. Learner consent required before public sharing. Revocation mechanisms needed for accuracy. FERPA considerations when badges are issued by educational institutions.",
      "https://firsteducore.org/ontology#dataClassification": "credential-metadata",
      "https://firsteducore.org/ontology#regulation": [
        "FERPA (educational contexts)",
        "GDPR (international)"
      ]
    },
