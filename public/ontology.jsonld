    {
      "@id": "https://firsteducore.org/ontology#ceds-alignment/case-v1/credentials",
      "@type": "https://firsteducore.org/ontology#CedsAlignment",
      "https://firsteducore.org/ontology#specification": {
        "@id": "https://firsteducore.org/ontology#spec/case-v1"
      },
      "https://firsteducore.org/ontology#cedsDomain": {
        "@id": "https://firsteducore.org/ontology#ceds-domain/credentials"
      },
      "https://firsteducore.org/ontology#alignmentStatus": "partial",
      "https://firsteducore.org/ontology#notes": "CASE defines competency criteria that inform credential requirements but does not model credential issuance or attainment.",
      "https://firsteducore.org/ontology#gapNotes": "CEDS Credential includes attainment date, issuing org, and verification — CASE covers competency definitions only.",
      "https://firsteducore.org/ontology#cedsElement": [
        "CredentialDefinition"
      ],
      "https://firsteducore.org/ontology#alignmentPrivacyRisk": "low"
    },
    {
      "@id": "https://firsteducore.org/ontology#ceds-alignment/case-v1/competencies",
      "@type": "https://firsteducore.org/ontology#CedsAlignment",
      "https://firsteducore.org/ontology#specification": {
        "@id": "https://firsteducore.org/ontology#spec/case-v1"
      },
      "https://firsteducore.org/ontology#cedsDomain": {
        "@id": "https://firsteducore.org/ontology#ceds-domain/competencies"
      },
      "https://firsteducore.org/ontology#alignmentStatus": "full",
      "https://firsteducore.org/ontology#notes": "CASE is purpose-built for competency framework exchange. Deep alignment with CEDS CompetencyFramework, CompetencyDefinition, and LearningStandard entities.",
      "https://firsteducore.org/ontology#cedsElement": [
        "CompetencyFramework",
        "CompetencyDefinition",
        "CompetencyDefinition",
        "CompetencyDefinition"
      ],
      "https://firsteducore.org/ontology#alignmentPrivacyRisk": "low"
    },
    {
      "@id": "https://firsteducore.org/ontology#ceds-alignment/case-v1/workforce",
      "@type": "https://firsteducore.org/ontology#CedsAlignment",
      "https://firsteducore.org/ontology#specification": {
        "@id": "https://firsteducore.org/ontology#spec/case-v1"
      },
      "https://firsteducore.org/ontology#cedsDomain": {
        "@id": "https://firsteducore.org/ontology#ceds-domain/workforce"
      },
      "https://firsteducore.org/ontology#alignmentStatus": "partial",
      "https://firsteducore.org/ontology#notes": "Workforce competency frameworks can be published via CASE. Does not model employment records or workforce programs directly.",
      "https://firsteducore.org/ontology#gapNotes": "CEDS Workforce includes EmploymentRecord and WorkforceProgram — not in CASE scope.",
      "https://firsteducore.org/ontology#cedsElement": [
        "StandardOccupationalClassification",
        "CompetencyDefinition"
      ],
      "https://firsteducore.org/ontology#alignmentPrivacyRisk": "low"
    },
    {
      "@id": "https://firsteducore.org/ontology#ceds-alignment/case-v1/assessments",
      "@type": "https://firsteducore.org/ontology#CedsAlignment",
      "https://firsteducore.org/ontology#specification": {
        "@id": "https://firsteducore.org/ontology#spec/case-v1"
      },
      "https://firsteducore.org/ontology#cedsDomain": {
        "@id": "https://firsteducore.org/ontology#ceds-domain/assessments"
      },
      "https://firsteducore.org/ontology#alignmentStatus": "gap",
      "https://firsteducore.org/ontology#notes": "CASE does not model assessments. Competency frameworks may inform assessment design but CASE is not an assessment standard.",
      "https://firsteducore.org/ontology#gapNotes": "CEDS Assessments domain (test structure, items, results) is entirely outside CASE scope.",
      "https://firsteducore.org/ontology#alignmentPrivacyRisk": "low"
    },
    {
      "@id": "https://firsteducore.org/ontology#ceds-alignment/case-v1/learningResources",
      "@type": "https://firsteducore.org/ontology#CedsAlignment",
      "https://firsteducore.org/ontology#specification": {
        "@id": "https://firsteducore.org/ontology#spec/case-v1"
      },
      "https://firsteducore.org/ontology#cedsDomain": {
        "@id": "https://firsteducore.org/ontology#ceds-domain/learningResources"
      },
      "https://firsteducore.org/ontology#alignmentStatus": "partial",
      "https://firsteducore.org/ontology#notes": "Competency frameworks published via CASE can be used to align learning resources, but CASE does not model resource metadata.",
      "https://firsteducore.org/ontology#gapNotes": "CEDS Learning Resources includes URL, media type, educational level — not in CASE scope.",
      "https://firsteducore.org/ontology#cedsElement": [
        "LearningResource"
      ],
      "https://firsteducore.org/ontology#alignmentPrivacyRisk": "low"
    },
    {
      "@id": "https://firsteducore.org/ontology#ceds-alignment/case-v1/k12",
      "@type": "https://firsteducore.org/ontology#CedsAlignment",
      "https://firsteducore.org/ontology#specification": {
        "@id": "https://firsteducore.org/ontology#spec/case-v1"
      },
      "https://firsteducore.org/ontology#cedsDomain": {
        "@id": "https://firsteducore.org/ontology#ceds-domain/k12"
      },
      "https://firsteducore.org/ontology#alignmentStatus": "full",
      "https://firsteducore.org/ontology#notes": "CASE is widely adopted for K–12 state academic standards exchange. US state education agencies publish standards via CASE Network.",
      "https://firsteducore.org/ontology#cedsElement": [
        "CompetencySet",
        "CompetencyDefinition",
        "CompetencyDefinition"
      ],
      "https://firsteducore.org/ontology#alignmentPrivacyRisk": "low"
    },
    {
      "@id": "https://firsteducore.org/ontology#ceds-alignment/case-v1/postsecondary",
      "@type": "https://firsteducore.org/ontology#CedsAlignment",
      "https://firsteducore.org/ontology#specification": {
        "@id": "https://firsteducore.org/ontology#spec/case-v1"
      },
      "https://firsteducore.org/ontology#cedsDomain": {
        "@id": "https://firsteducore.org/ontology#ceds-domain/postsecondary"
      },
      "https://firsteducore.org/ontology#alignmentStatus": "partial",
      "https://firsteducore.org/ontology#notes": "Postsecondary competency frameworks can use CASE but adoption is lower than K–12. Alignment with CEDS postsecondary competency records.",
      "https://firsteducore.org/ontology#gapNotes": "CEDS Postsecondary includes enrollment, program, degree — CASE covers only competency definitions.",
      "https://firsteducore.org/ontology#cedsElement": [
        "PostsecondaryStudentAcademicRecord"
      ],
      "https://firsteducore.org/ontology#alignmentPrivacyRisk": "low"
    },
    {
      "@id": "https://firsteducore.org/ontology#ceds-alignment/case-v1/cte",
      "@type": "https://firsteducore.org/ontology#CedsAlignment",
      "https://firsteducore.org/ontology#specification": {
        "@id": "https://firsteducore.org/ontology#spec/case-v1"
      },
      "https://firsteducore.org/ontology#cedsDomain": {
        "@id": "https://firsteducore.org/ontology#ceds-domain/cte"
      },
      "https://firsteducore.org/ontology#alignmentStatus": "full",
      "https://firsteducore.org/ontology#notes": "CTE industry competency frameworks are a primary CASE use case. Strong alignment with CEDS CTE occupational cluster and industry alignment elements.",
      "https://firsteducore.org/ontology#cedsElement": [
        "ProgramParticipationCareerAndTechnical",
        "CareerCluster",
        "CareerAndTechnicalEducationInstructorIndustryCertification"
      ],
      "https://firsteducore.org/ontology#alignmentPrivacyRisk": "low"
    },
    {
      "@id": "https://firsteducore.org/ontology#ceds-alignment/case-v1/adultEd",
