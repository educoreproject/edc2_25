    {
      "@id": "https://firsteducore.org/ontology#ceds-alignment/clr-v2/authN",
      "@type": "https://firsteducore.org/ontology#CedsAlignment",
      "https://firsteducore.org/ontology#specification": {
        "@id": "https://firsteducore.org/ontology#spec/clr-v2"
      },
      "https://firsteducore.org/ontology#cedsDomain": {
        "@id": "https://firsteducore.org/ontology#ceds-domain/authN"
      },
      "https://firsteducore.org/ontology#alignmentStatus": "partial",
      "https://firsteducore.org/ontology#notes": "CLR uses W3C VC identity infrastructure (DIDs) for issuer and holder identification. Consent management aligns with CEDS authorization concepts.",
      "https://firsteducore.org/ontology#gapNotes": "CEDS Auth models full system access and role management beyond CLR identity scope.",
