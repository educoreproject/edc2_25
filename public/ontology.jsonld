    },
    {
      "@id": "https://firsteducore.org/ontology#domain-privacy/assessments",
      "@type": "https://firsteducore.org/ontology#DomainPrivacyProfile",
      "https://firsteducore.org/ontology#privacyRiskLevel": "high",
      "https://firsteducore.org/ontology#privacyRiskRationale": "Assessment scores are explicit FERPA education records when maintained by an educational institution. COPPA applies to assessments given to children under 13. Consent required before disclosure to third parties.",
      "https://firsteducore.org/ontology#piiCategories": [
        {
          "@id": "https://firsteducore.org/ontology#pii-category/AssessmentResult"
