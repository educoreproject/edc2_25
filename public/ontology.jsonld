      },
      "https://firsteducore.org/ontology#alignmentStatus": "full",
      "https://firsteducore.org/ontology#notes": "OB3 is a credential issuance standard. Full alignment with CEDS Credential entity including issuer, award status, and criteria.",
      "https://firsteducore.org/ontology#cedsElement": [
        "Credential",
        "CredentialType",
        "CredentialAward",
        "CredentialDefinition"
      ],
      "https://firsteducore.org/ontology#alignmentPrivacyRisk": "high",
