    {
      "@id": "https://firsteducore.org/ontology#spec/clr-v2",
      "@type": "https://firsteducore.org/ontology#Specification",
      "dcterms:identifier": "clr-v2",
      "dcterms:title": "Comprehensive Learner Record (CLR) 2.0",
      "dcterms:description": "1EdTech standard for comprehensive, portable learner achievement records. CLR 2.0 extends Open Badges 3.0 to aggregate multiple achievements, competencies, and experiences into a single verifiable record aligned with W3C Verifiable Credentials.",
      "dcterms:type": "Standard",
      "https://firsteducore.org/ontology#category": "Learner Records",
      "https://firsteducore.org/ontology#owner": "1EdTech Consortium",
      "https://firsteducore.org/ontology#governanceBody": "1EdTech Consortium",
      "dcterms:modified": {
        "@value": "2024-12-01",
        "@type": "xsd:date"
      },
      "https://firsteducore.org/ontology#version": "2.0",
      "https://firsteducore.org/ontology#accessLevel": "open",
      "https://firsteducore.org/ontology#opennessStatus": "open",
      "https://firsteducore.org/ontology#status": "approved",
      "https://firsteducore.org/ontology#aiSummary": "Standard for aggregating achievements, badges, and competencies into a comprehensive, verifiable learner record. Use when building learner portfolios, transcript alternatives, or comprehensive credential packages.",
      "https://firsteducore.org/ontology#aiUnlocksSummary": "Enables your product to create comprehensive, portable learner records that aggregate badges, credentials, competencies, and experiences into a single verifiable package. Unlocks holistic learner profiles, transcript modernization, competency-based record-keeping, and cross-institutional record portability — giving learners a complete, verifiable picture of their achievements.",
      "https://firsteducore.org/ontology#aiTaxonomy": [
        "learner-record",
        "credential-aggregation",
        "portable-record"
      ],
      "dcterms:subject": [
        "CLR",
        "comprehensive-learner-record",
        "learner-record",
        "1EdTech",
        "verifiable-credentials",
        "JSON-LD",
        "portable-record"
      ],
      "https://firsteducore.org/ontology#implementationBurden": "high",
      "https://firsteducore.org/ontology#implementationBurdenRationale": "CLR 2.0 builds on OB3 and W3C VC, requiring familiarity with both. Aggregating multiple credential types into a coherent record adds data modeling complexity. Managed platforms exist but full custom implementation is significant.",
      "https://firsteducore.org/ontology#requiredCapability": [
        "JSON-LD processing",
        "W3C VC signing infrastructure",
        "Credential aggregation pipeline",
        "Learner consent UI",
        "Open Badges 3.0 compatibility"
      ],
      "https://firsteducore.org/ontology#knownAdopter": [
        "Western Governors University",
        "AACRAO (Digital Connect)",
        "Parchment",
        "National Student Clearinghouse"
      ],
      "https://firsteducore.org/ontology#compatibilityNotes": "CLR 2.0 is a superset of Open Badges 3.0 — every OB3 badge can be included in a CLR. Both are built on W3C Verifiable Credentials. CTDL can describe CLR-issued credentials for registry transparency. CASE competency identifiers can be referenced in CLR achievement criteria. The entire LER stack fits together without conflicts.",
      "foaf:page": {
        "@id": "https://www.1edtech.org/standards/clr"
      },
      "https://firsteducore.org/ontology#implementationGuidance": "Begin by implementing Open Badges 3.0 support first — CLR extends OB3. Start as a CLR consumer: accept and display CLR records from other issuers. Phase 2: aggregate your own badges/achievements into CLR records. Phase 3: implement full issuance with consent management and VC signing. Use 1EdTech conformance suite for validation.",
      "https://firsteducore.org/ontology#commonlyPairedWith": [
        {
          "@id": "https://firsteducore.org/ontology#spec/open-badges-v3"
        },
        {
          "@id": "https://firsteducore.org/ontology#spec/case-v1"
        },
        {
          "@id": "https://firsteducore.org/ontology#spec/lrw-competency-framework"
        }
      ],
      "https://firsteducore.org/ontology#relatedResource": [
        {
          "@id": "https://firsteducore.org/ontology#spec/open-badges-v3"
        },
        {
          "@id": "https://firsteducore.org/ontology#spec/case-v1"
        },
        {
          "@id": "https://firsteducore.org/ontology#spec/lrw-competency-framework"
        }
      ],
      "https://firsteducore.org/ontology#burdenRubric": {
        "@id": "https://firsteducore.org/ontology#burden-rubric/clr-v2"
      },
      "https://firsteducore.org/ontology#equityConsiderations": {
        "@id": "https://firsteducore.org/ontology#equity/clr-v2"
      },
      "https://firsteducore.org/ontology#privacyConsiderations": {
        "@id": "https://firsteducore.org/ontology#privacy/clr-v2"
      },
      "https://firsteducore.org/ontology#referenceImplementation": [
        {
          "@id": "https://firsteducore.org/ontology#ref-impl/clr-v2/0"
        },
        {
          "@id": "https://firsteducore.org/ontology#ref-impl/clr-v2/1"
        }
      ],
      "https://firsteducore.org/ontology#technicalDocLink": [
