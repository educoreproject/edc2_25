      "https://firsteducore.org/ontology#gapNotes": "CEDS Early Learning developmental domains not represented.",
      "https://firsteducore.org/ontology#alignmentPrivacyRisk": "low"
    },
    {
      "@id": "https://firsteducore.org/ontology#ceds-alignment/lrw-competency-framework/authN",
      "@type": "https://firsteducore.org/ontology#CedsAlignment",
      "https://firsteducore.org/ontology#specification": {
        "@id": "https://firsteducore.org/ontology#spec/lrw-competency-framework"
      },
      "https://firsteducore.org/ontology#cedsDomain": {
        "@id": "https://firsteducore.org/ontology#ceds-domain/authN"
      },
      "https://firsteducore.org/ontology#alignmentStatus": "full",
      "https://firsteducore.org/ontology#notes": "LER standard normatively requires W3C DIDs for identity. Defines trust, verification, and wallet roles that directly address authentication and authorization.",
      "https://firsteducore.org/ontology#cedsElement": [
        "PersonIdentification",
        "AuthorizationDocument"
      ],
      "https://firsteducore.org/ontology#alignmentPrivacyRisk": "high",
