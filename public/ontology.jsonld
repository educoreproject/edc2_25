    {
      "@id": "https://firsteducore.org/ontology#spec/ctdl",
      "@type": "https://firsteducore.org/ontology#Specification",
      "dcterms:identifier": "ctdl",
      "dcterms:title": "Credential Transparency Description Language (CTDL)",
      "dcterms:description": "Linked-data vocabulary (JSON-LD/RDF) for describing credentials, organizations, competencies, and their relationships. Maintained by Credential Engine, CTDL powers the Credential Registry and enables machine-readable credential transparency at national scale.",
      "dcterms:type": "Standard",
      "https://firsteducore.org/ontology#category": "Credential Transparency",
      "https://firsteducore.org/ontology#owner": "Credential Engine",
      "https://firsteducore.org/ontology#governanceBody": "Credential Engine",
      "dcterms:modified": {
        "@value": "2025-08-01",
        "@type": "xsd:date"
      },
      "https://firsteducore.org/ontology#version": "current",
      "https://firsteducore.org/ontology#accessLevel": "open",
      "https://firsteducore.org/ontology#opennessStatus": "open",
      "https://firsteducore.org/ontology#status": "approved",
      "https://firsteducore.org/ontology#aiSummary": "Linked-data vocabulary for describing credentials, their requirements, and issuing organizations. Use when publishing or consuming credential metadata for transparency and discovery.",
      "https://firsteducore.org/ontology#aiUnlocksSummary": "Enables your product to describe credentials in a machine-readable, semantically rich format that the Credential Registry and search engines can index. Unlocks credential discovery, comparison, and pathway mapping at national scale — letting learners and employers find and evaluate credentials across thousands of providers.",
      "https://firsteducore.org/ontology#aiTaxonomy": [
        "credential-vocabulary",
        "linked-data",
        "transparency"
      ],
      "dcterms:subject": [
        "CTDL",
        "credential-transparency",
        "linked-data",
        "JSON-LD",
        "RDF",
        "Credential-Engine",
        "registry"
      ],
      "https://firsteducore.org/ontology#implementationBurden": "medium",
      "https://firsteducore.org/ontology#implementationBurdenRationale": "JSON-LD/RDF requires familiarity with linked data concepts. Credential Engine provides tools and APIs that reduce the burden. Publishing to the Registry has a structured onboarding process.",
      "https://firsteducore.org/ontology#requiredCapability": [
        "JSON-LD understanding",
        "Credential data modeling",
        "REST API client (for Registry integration)"
      ],
      "https://firsteducore.org/ontology#knownAdopter": [
        "Credential Engine publisher network (4,000+ organizations)",
        "US state longitudinal data systems",
        "Lumina Foundation grantees",
        "EMSI/Lightcast"
      ],
      "https://firsteducore.org/ontology#compatibilityNotes": "CTDL is the description/transparency layer while Open Badges and CLR are the issuance/record layers. CTDL describes what a credential IS; OB3/CLR record that a learner HAS one. They are complementary, not competing. CTDL uses JSON-LD; ensure JSON-LD tooling is available if integrating with CASE (plain JSON).",
      "foaf:page": {
        "@id": "https://credreg.net/ctdl/terms"
      },
      "https://firsteducore.org/ontology#authoritativeRepoUrl": {
        "@id": "https://github.com/CredentialEngine/CTDL_Json_Validation_Schema"
      },
      "https://firsteducore.org/ontology#implementationGuidance": "Begin by exploring the Credential Registry search to understand CTDL data in practice. Map your credentials to CTDL terms using the CTDL Handbook. Use the Credential Engine publisher tool for initial data entry. For programmatic integration, use the Registry API.",
      "https://firsteducore.org/ontology#commonlyPairedWith": [
        {
          "@id": "https://firsteducore.org/ontology#spec/case-v1"
        },
        {
          "@id": "https://firsteducore.org/ontology#spec/open-badges-v3"
        },
        {
          "@id": "https://firsteducore.org/ontology#spec/lrw-competency-framework"
        },
        {
          "@id": "https://firsteducore.org/ontology#spec/clr-v2"
        }
      ],
      "https://firsteducore.org/ontology#relatedResource": [
        {
          "@id": "https://firsteducore.org/ontology#spec/case-v1"
        },
