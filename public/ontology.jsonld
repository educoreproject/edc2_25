      },
      "https://firsteducore.org/ontology#cedsDomain": {
        "@id": "https://firsteducore.org/ontology#ceds-domain/authN"
      },
      "https://firsteducore.org/ontology#alignmentStatus": "gap",
      "https://firsteducore.org/ontology#notes": "CTDL does not model authentication or authorization. Registry access uses standard API keys.",
      "https://firsteducore.org/ontology#alignmentPrivacyRisk": "low"
    },
    {
      "@id": "https://firsteducore.org/ontology#ceds-alignment/ctdl/implVars",
      "@type": "https://firsteducore.org/ontology#CedsAlignment",
      "https://firsteducore.org/ontology#specification": {
        "@id": "https://firsteducore.org/ontology#spec/ctdl"
      },
      "https://firsteducore.org/ontology#cedsDomain": {
        "@id": "https://firsteducore.org/ontology#ceds-domain/implVars"
      },
      "https://firsteducore.org/ontology#alignmentStatus": "partial",
      "https://firsteducore.org/ontology#notes": "Organization identifiers in CTDL (CTID, DUNS) partially align with CEDS Implementation Variables for organizational identification.",
      "https://firsteducore.org/ontology#cedsElement": [
        "ImplementationStatus",
        "OrganizationIdentificationSystem"
      ],
      "https://firsteducore.org/ontology#alignmentPrivacyRisk": "low"
    },
    {
      "@id": "https://firsteducore.org/ontology#ceds-alignment/ctdl/facilities",
