    {
      "@id": "https://firsteducore.org/ontology#equity/lrw-competency-framework",
      "@type": "https://firsteducore.org/ontology#EquityConsideration",
      "https://firsteducore.org/ontology#level": "medium-concern",
      "https://firsteducore.org/ontology#notes": "The standard acknowledges the need for equitable access to credential infrastructure. Digital wallet requirements may create barriers for learners without smartphones or stable internet. Alternative presentation methods should be supported.",
      "https://firsteducore.org/ontology#lifDerived": {
        "@value": "false",
        "@type": "xsd:boolean"
      }
    },
    {
      "@id": "https://firsteducore.org/ontology#privacy/lrw-competency-framework",
      "@type": "https://firsteducore.org/ontology#PrivacyConsideration",
      "https://firsteducore.org/ontology#level": "medium-concern",
      "https://firsteducore.org/ontology#notes": "LER ecosystems involve PII in verifiable credentials. The standard recommends selective disclosure and privacy-preserving verification. Implementers must address FERPA compliance for education records and consent management for credential sharing.",
      "https://firsteducore.org/ontology#dataClassification": "architectural-standard",
      "https://firsteducore.org/ontology#regulation": [
        "FERPA",
        "state privacy laws"
      ]
    },
