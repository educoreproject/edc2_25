    },
    {
      "@id": "https://firsteducore.org/ontology#domain-privacy/credentials",
      "@type": "https://firsteducore.org/ontology#DomainPrivacyProfile",
      "https://firsteducore.org/ontology#privacyRiskLevel": "high",
      "https://firsteducore.org/ontology#privacyRiskRationale": "Credential records bind identity to achievement, requiring PII (name, DOB, institution) and triggering FERPA education record status. Consent required before sharing outside the issuing institution.",
      "https://firsteducore.org/ontology#piiCategories": [
        {
          "@id": "https://firsteducore.org/ontology#pii-category/DirectIdentifier"
        },
        {
          "@id": "https://firsteducore.org/ontology#pii-category/EducationalRecord"
        },
        {
          "@id": "https://firsteducore.org/ontology#pii-category/CredentialMetadata"
        }
      ],
      "https://firsteducore.org/ontology#applicableRegulation": [
        "FERPA",
        "COPPA",
        "NDPA"
      ],
      "https://firsteducore.org/ontology#consentRequired": true,
      "https://firsteducore.org/ontology#transferRisk": "high"
    },
    {
      "@id": "https://firsteducore.org/ontology#domain-privacy/competencies",
      "@type": "https://firsteducore.org/ontology#DomainPrivacyProfile",
      "https://firsteducore.org/ontology#privacyRiskLevel": "low",
      "https://firsteducore.org/ontology#privacyRiskRationale": "Competency framework definitions are public vocabulary — no PII in the framework itself. Privacy risk arises only when competency data is linked to a specific learner record.",
      "https://firsteducore.org/ontology#piiCategories": [],
      "https://firsteducore.org/ontology#applicableRegulation": [],
      "https://firsteducore.org/ontology#consentRequired": false,
