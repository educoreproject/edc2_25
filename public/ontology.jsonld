      },
      "https://firsteducore.org/ontology#cedsDomain": {
        "@id": "https://firsteducore.org/ontology#ceds-domain/competencies"
      },
      "https://firsteducore.org/ontology#alignmentStatus": "partial",
      "https://firsteducore.org/ontology#notes": "Badges can reference competency definitions as achievement criteria but do not define competency frameworks themselves.",
      "https://firsteducore.org/ontology#gapNotes": "CEDS Competencies domain defines full framework structure; OB3 only references competencies.",
      "https://firsteducore.org/ontology#cedsElement": [
        "CompetencyDefinition"
      ],
      "https://firsteducore.org/ontology#alignmentPrivacyRisk": "low"
    },
    {
