      },
      "https://firsteducore.org/ontology#alignmentStatus": "full",
      "https://firsteducore.org/ontology#notes": "Skills-based hiring and career advancement are primary use cases. LER Talent Marketplace role directly addresses workforce credential matching.",
      "https://firsteducore.org/ontology#cedsElement": [
        "WorkforceProgramParticipation",
        "WorkforceEmploymentQuarterlyData",
        "StandardOccupationalClassification",
        "CompetencyDefinition"
      ],
      "https://firsteducore.org/ontology#alignmentPrivacyRisk": "medium"
    },
    {
      "@id": "https://firsteducore.org/ontology#ceds-alignment/lrw-competency-framework/assessments",
      "@type": "https://firsteducore.org/ontology#CedsAlignment",
      "https://firsteducore.org/ontology#specification": {
        "@id": "https://firsteducore.org/ontology#spec/lrw-competency-framework"
      },
      "https://firsteducore.org/ontology#cedsDomain": {
        "@id": "https://firsteducore.org/ontology#ceds-domain/assessments"
      },
      "https://firsteducore.org/ontology#alignmentStatus": "partial",
      "https://firsteducore.org/ontology#notes": "LER credentials can carry assessment outcomes as verifiable claims. The standard does not model assessment event structure.",
      "https://firsteducore.org/ontology#gapNotes": "CEDS Assessments domain models full assessment lifecycle; LER standard focuses on credential-level outcomes.",
      "https://firsteducore.org/ontology#cedsElement": [
        "AssessmentResult"
      ],
      "https://firsteducore.org/ontology#alignmentPrivacyRisk": "medium",
      "https://firsteducore.org/ontology#piiField": [
        {
          "@id": "https://firsteducore.org/ontology#pii-field/lrw/credentialSubject"
        }
      ]
    },
    {
