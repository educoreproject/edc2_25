    {
      "@id": "https://firsteducore.org/ontology#equity/clr-v2",
      "@type": "https://firsteducore.org/ontology#EquityConsideration",
      "https://firsteducore.org/ontology#level": "medium-concern",
      "https://firsteducore.org/ontology#notes": "CLR aggregation complexity can create a digital divide. Learners with fewer institutional touchpoints may have thinner CLR records, potentially disadvantaging them. Ensure CLR viewers present non-traditional achievements equitably. Wallet UX accessibility is critical.",
      "https://firsteducore.org/ontology#lifDerived": {
        "@value": "true",
        "@type": "xsd:boolean"
      }
    },
    {
      "@id": "https://firsteducore.org/ontology#privacy/clr-v2",
      "@type": "https://firsteducore.org/ontology#PrivacyConsideration",
      "https://firsteducore.org/ontology#level": "high-concern",
      "https://firsteducore.org/ontology#notes": "CLR records aggregate comprehensive learner data including achievements, competencies, and institutional history. FERPA compliance mandatory for educational issuers. Learner consent required for each achievement included. Selective disclosure mechanisms (from W3C VC) should be implemented to let learners share only relevant portions.",
      "https://firsteducore.org/ontology#dataClassification": "PII / educational-record",
      "https://firsteducore.org/ontology#regulation": [
        "FERPA",
        "COPPA (under-13 contexts)",
        "GDPR (international)",
        "state privacy laws"
      ]
    },
