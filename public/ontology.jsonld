        "@id": "https://firsteducore.org/ontology#ceds-domain/postsecondary"
      },
      "https://firsteducore.org/ontology#alignmentStatus": "full",
      "https://firsteducore.org/ontology#notes": "Postsecondary credential issuance and verification is a primary LER use case. Strong alignment with CEDS postsecondary credential elements.",
      "https://firsteducore.org/ontology#cedsElement": [
        "PersonDegreeOrCertificate",
        "PostsecondaryStudentAcademicRecord",
        "PostsecondaryProgram"
      ],
      "https://firsteducore.org/ontology#alignmentPrivacyRisk": "medium"
    },
    {
      "@id": "https://firsteducore.org/ontology#ceds-alignment/lrw-competency-framework/cte",
