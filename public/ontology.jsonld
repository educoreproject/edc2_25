    {
      "@id": "https://firsteducore.org/ontology#ceds-alignment/open-badges-v3/implVars",
      "@type": "https://firsteducore.org/ontology#CedsAlignment",
      "https://firsteducore.org/ontology#specification": {
        "@id": "https://firsteducore.org/ontology#spec/open-badges-v3"
      },
      "https://firsteducore.org/ontology#cedsDomain": {
