      "@id": "https://firsteducore.org/ontology#burden-dimension/lrw-competency-framework/engineering",
      "@type": "https://firsteducore.org/ontology#BurdenDimension",
      "rdfs:label": "engineering",
      "https://firsteducore.org/ontology#level": "moderate",
      "https://firsteducore.org/ontology#note": "Aligning an existing system to the LER architecture requires moderate effort. Higher if building W3C VC infrastructure from scratch."
    },
    {
      "@id": "https://firsteducore.org/ontology#burden-dimension/lrw-competency-framework/infrastructure",
      "@type": "https://firsteducore.org/ontology#BurdenDimension",
      "rdfs:label": "infrastructure",
      "https://firsteducore.org/ontology#level": "moderate",
      "https://firsteducore.org/ontology#note": "Requires W3C VC-compatible credential infrastructure. Digital wallet integration needed for Holder role. Registry infrastructure for governance role."
    },
    {
      "@id": "https://firsteducore.org/ontology#burden-dimension/lrw-competency-framework/legal",
      "@type": "https://firsteducore.org/ontology#BurdenDimension",
      "rdfs:label": "legal",
      "https://firsteducore.org/ontology#level": "low",
      "https://firsteducore.org/ontology#note": "IEEE standard is publicly referenced. No licensing fees for conformance. Data sharing agreements needed for multi-party ecosystems."
    },
    {
