    {
      "@id": "https://firsteducore.org/ontology#equity/case-v1",
      "@type": "https://firsteducore.org/ontology#EquityConsideration",
      "https://firsteducore.org/ontology#level": "low-concern",
      "https://firsteducore.org/ontology#notes": "Framework exchange standard with no PII. Equity concern: published frameworks may embed curriculum biases. Review competency language for cultural neutrality before adoption.",
      "https://firsteducore.org/ontology#lifDerived": {
        "@value": "false",
        "@type": "xsd:boolean"
      }
    },
