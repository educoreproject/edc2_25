      },
      "https://firsteducore.org/ontology#alignmentStatus": "partial",
      "https://firsteducore.org/ontology#notes": "Badge criteria can link to learning resources. OB3 does not model CEDS LearningResource metadata fields.",
      "https://firsteducore.org/ontology#cedsElement": [
        "LearningResource"
      ],
      "https://firsteducore.org/ontology#alignmentPrivacyRisk": "low"
    },
