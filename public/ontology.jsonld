    {
      "@id": "https://firsteducore.org/ontology#equity/ctdl",
      "@type": "https://firsteducore.org/ontology#EquityConsideration",
      "https://firsteducore.org/ontology#level": "low-concern",
      "https://firsteducore.org/ontology#notes": "Vocabulary standard describing credentials. Equity benefit: makes credential information transparent and discoverable to underserved populations. Concern: credential descriptions may omit alternative or non-traditional pathways if not intentionally included.",
      "https://firsteducore.org/ontology#lifDerived": {
        "@value": "false",
        "@type": "xsd:boolean"
      }
    },
    {
      "@id": "https://firsteducore.org/ontology#privacy/ctdl",
