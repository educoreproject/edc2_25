        "@id": "https://firsteducore.org/ontology#ceds-domain/workforce"
      },
      "https://firsteducore.org/ontology#alignmentStatus": "partial",
      "https://firsteducore.org/ontology#notes": "Workforce badges and micro-credentials exist as an OB3 use case. Badges can reference occupational alignments.",
      "https://firsteducore.org/ontology#gapNotes": "CEDS Workforce includes EmploymentRecord and WorkforceProgram — not modeled in OB3.",
      "https://firsteducore.org/ontology#cedsElement": [
        "CompetencyDefinition",
        "StandardOccupationalClassification"
      ],
      "https://firsteducore.org/ontology#alignmentPrivacyRisk": "low"
    },
    {
      "@id": "https://firsteducore.org/ontology#ceds-alignment/open-badges-v3/assessments",
