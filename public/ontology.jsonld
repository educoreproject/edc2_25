    },
    {
      "@id": "https://firsteducore.org/ontology#domain-privacy/k12",
      "@type": "https://firsteducore.org/ontology#DomainPrivacyProfile",
      "https://firsteducore.org/ontology#privacyRiskLevel": "high",
      "https://firsteducore.org/ontology#privacyRiskRationale": "K-12 enrollment, attendance, discipline, and academic records are the core FERPA-protected data class. COPPA applies broadly (under-13 students). Highest state law coverage. Parental consent required for students under 18; student consent at 18+.",
      "https://firsteducore.org/ontology#piiCategories": [
        {
          "@id": "https://firsteducore.org/ontology#pii-category/DirectIdentifier"
        },
        {
          "@id": "https://firsteducore.org/ontology#pii-category/EducationalRecord"
        },
        {
          "@id": "https://firsteducore.org/ontology#pii-category/BehavioralData"
        },
        {
          "@id": "https://firsteducore.org/ontology#pii-category/BiographicData"
        }
      ],
      "https://firsteducore.org/ontology#applicableRegulation": [
        "FERPA",
        "COPPA",
        "NDPA",
        "state privacy laws"
      ],
      "https://firsteducore.org/ontology#consentRequired": true,
      "https://firsteducore.org/ontology#transferRisk": "high"
    },
    {
      "@id": "https://firsteducore.org/ontology#domain-privacy/postsecondary",
      "@type": "https://firsteducore.org/ontology#DomainPrivacyProfile",
      "https://firsteducore.org/ontology#privacyRiskLevel": "high",
      "https://firsteducore.org/ontology#privacyRiskRationale": "Postsecondary academic transcripts, degree records, enrollment, and financial aid records are FERPA-protected. Students have right to access and control disclosure. Transcripts shared with employers or other institutions require student consent.",
      "https://firsteducore.org/ontology#piiCategories": [
        {
          "@id": "https://firsteducore.org/ontology#pii-category/EducationalRecord"
        },
        {
          "@id": "https://firsteducore.org/ontology#pii-category/InstitutionalHistory"
        },
        {
          "@id": "https://firsteducore.org/ontology#pii-category/DirectIdentifier"
        }
      ],
      "https://firsteducore.org/ontology#applicableRegulation": [
        "FERPA",
        "state privacy laws"
      ],
      "https://firsteducore.org/ontology#consentRequired": true,
      "https://firsteducore.org/ontology#transferRisk": "high"
    },
    {
      "@id": "https://firsteducore.org/ontology#domain-privacy/cte",
      "@type": "https://firsteducore.org/ontology#DomainPrivacyProfile",
      "https://firsteducore.org/ontology#privacyRiskLevel": "medium",
      "https://firsteducore.org/ontology#privacyRiskRationale": "CTE program data links student records to industry certifications and workforce participation. FERPA applies when records are maintained by an educational institution. Data sharing with industry partners requires consent.",
      "https://firsteducore.org/ontology#piiCategories": [
        {
          "@id": "https://firsteducore.org/ontology#pii-category/CredentialMetadata"
        },
        {
          "@id": "https://firsteducore.org/ontology#pii-category/InstitutionalHistory"
        }
      ],
      "https://firsteducore.org/ontology#applicableRegulation": [
        "FERPA",
        "state privacy laws"
      ],
      "https://firsteducore.org/ontology#consentRequired": false,
      "https://firsteducore.org/ontology#transferRisk": "medium"
    },
    {
      "@id": "https://firsteducore.org/ontology#domain-privacy/adultEd",
      "@type": "https://firsteducore.org/ontology#DomainPrivacyProfile",
      "https://firsteducore.org/ontology#privacyRiskLevel": "medium",
      "https://firsteducore.org/ontology#privacyRiskRationale": "Adult education program participation data is subject to FERPA when linked to postsecondary programs. State-level adult education privacy laws apply. Workforce data crossover creates additional compliance obligations.",
      "https://firsteducore.org/ontology#piiCategories": [
        {
          "@id": "https://firsteducore.org/ontology#pii-category/EducationalRecord"
        },
        {
          "@id": "https://firsteducore.org/ontology#pii-category/BiographicData"
        }
      ],
      "https://firsteducore.org/ontology#applicableRegulation": [
        "FERPA (postsecondary-linked)",
        "state privacy laws"
      ],
      "https://firsteducore.org/ontology#consentRequired": false,
      "https://firsteducore.org/ontology#transferRisk": "medium"
    },
    {
      "@id": "https://firsteducore.org/ontology#domain-privacy/earlyLearning",
      "@type": "https://firsteducore.org/ontology#DomainPrivacyProfile",
      "https://firsteducore.org/ontology#privacyRiskLevel": "high",
      "https://firsteducore.org/ontology#privacyRiskRationale": "Early learning records involve the most sensitive age group (under-5, under-13). COPPA is the primary federal law; parental consent mandatory for any data collection or sharing. State early childhood privacy laws are often stricter than FERPA.",
      "https://firsteducore.org/ontology#piiCategories": [
        {
          "@id": "https://firsteducore.org/ontology#pii-category/DirectIdentifier"
        },
        {
          "@id": "https://firsteducore.org/ontology#pii-category/BiographicData"
        },
        {
          "@id": "https://firsteducore.org/ontology#pii-category/EducationalRecord"
        }
      ],
      "https://firsteducore.org/ontology#applicableRegulation": [
        "COPPA",
        "state early childhood laws",
        "FERPA (K-12 transition)"
      ],
      "https://firsteducore.org/ontology#consentRequired": true,
      "https://firsteducore.org/ontology#transferRisk": "high"
    },
    {
      "@id": "https://firsteducore.org/ontology#domain-privacy/authN",
      "@type": "https://firsteducore.org/ontology#DomainPrivacyProfile",
      "https://firsteducore.org/ontology#privacyRiskLevel": "high",
      "https://firsteducore.org/ontology#privacyRiskRationale": "Authentication and authorization tokens directly identify individuals and represent the highest security/privacy intersection in the stack. Breach of auth data enables identity takeover. DID documents and verifiable credential holder bindings must be protected against correlation attacks.",
      "https://firsteducore.org/ontology#piiCategories": [
        {
          "@id": "https://firsteducore.org/ontology#pii-category/DirectIdentifier"
        }
      ],
      "https://firsteducore.org/ontology#applicableRegulation": [
        "state breach notification laws",
        "FERPA (if tied to student record access)",
        "NDPA"
      ],
      "https://firsteducore.org/ontology#consentRequired": false,
      "https://firsteducore.org/ontology#transferRisk": "high"
    },
    {
      "@id": "https://firsteducore.org/ontology#domain-privacy/implVars",
      "@type": "https://firsteducore.org/ontology#DomainPrivacyProfile",
      "https://firsteducore.org/ontology#privacyRiskLevel": "low",
      "https://firsteducore.org/ontology#privacyRiskRationale": "Implementation variable metadata (configuration, versioning, capability declarations) does not inherently contain PII. Risk arises only if system configuration data inadvertently includes identifiers or access credentials.",
      "https://firsteducore.org/ontology#piiCategories": [],
      "https://firsteducore.org/ontology#applicableRegulation": [],
      "https://firsteducore.org/ontology#consentRequired": false,
      "https://firsteducore.org/ontology#transferRisk": "low"
    },
    {
      "@id": "https://firsteducore.org/ontology#domain-privacy/facilities",
      "@type": "https://firsteducore.org/ontology#DomainPrivacyProfile",
      "https://firsteducore.org/ontology#privacyRiskLevel": "low",
      "https://firsteducore.org/ontology#privacyRiskRationale": "Facilities data (building locations, capacity, room identifiers) does not contain PII under most privacy frameworks. Student location data may have privacy implications but is not modeled at the facilities metadata level.",
      "https://firsteducore.org/ontology#piiCategories": [],
      "https://firsteducore.org/ontology#applicableRegulation": [],
      "https://firsteducore.org/ontology#consentRequired": false,
      "https://firsteducore.org/ontology#transferRisk": "low"
    },
