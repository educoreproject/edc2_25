    },
    {
      "@id": "https://firsteducore.org/ontology#spec/open-badges-v3",
      "@type": "https://firsteducore.org/ontology#Specification",
      "dcterms:identifier": "open-badges-v3",
      "dcterms:title": "Open Badges 3.0",
      "dcterms:description": "1EdTech standard for issuing, displaying, and verifying digital badges and micro-credentials. Version 3.0 aligns with W3C Verifiable Credentials, enabling cryptographic verification and decentralized trust for achievement recognition.",
      "dcterms:type": "Standard",
      "https://firsteducore.org/ontology#category": "Digital Credentials",
      "https://firsteducore.org/ontology#owner": "1EdTech Consortium",
      "https://firsteducore.org/ontology#governanceBody": "1EdTech Consortium",
      "dcterms:modified": {
        "@value": "2024-12-01",
        "@type": "xsd:date"
      },
      "https://firsteducore.org/ontology#version": "3.0",
      "https://firsteducore.org/ontology#accessLevel": "open",
      "https://firsteducore.org/ontology#opennessStatus": "open",
      "https://firsteducore.org/ontology#status": "approved",
      "https://firsteducore.org/ontology#aiSummary": "Standard for issuing and verifying digital badges aligned with W3C VCs. Use when implementing achievement recognition, micro-credentialing, or skill badge systems.",
      "https://firsteducore.org/ontology#aiUnlocksSummary": "Enables your product to issue, display, and verify portable digital badges that learners can share across platforms and with employers. Unlocks micro-credentialing programs, stackable credential pathways, and verifiable achievement sharing — with W3C VC alignment providing cryptographic trust without centralized verification.",
      "https://firsteducore.org/ontology#aiTaxonomy": [
        "digital-badge",
        "micro-credential",
        "achievement-verification"
      ],
      "dcterms:subject": [
        "open-badges",
        "micro-credentials",
        "digital-badges",
        "1EdTech",
        "verifiable-credentials",
        "JSON-LD",
        "achievement"
      ],
      "https://firsteducore.org/ontology#implementationBurden": "medium",
      "https://firsteducore.org/ontology#implementationBurdenRationale": "OB3 is well-documented with robust tooling. The W3C VC alignment adds cryptographic complexity but managed services exist. Issuing is more complex than consuming/verifying.",
      "https://firsteducore.org/ontology#requiredCapability": [
        "JSON-LD processing",
        "Cryptographic signing (for issuers)",
        "Badge display/rendering UI",
        "REST API client"
      ],
      "https://firsteducore.org/ontology#knownAdopter": [
        "Credly",
        "Badgr/Instructure",
        "Accredible",
        "Digital Promise",
        "Mozilla Foundation (original OB creator)"
      ],
      "https://firsteducore.org/ontology#compatibilityNotes": "OB3 is built on W3C Verifiable Credentials, so it inherits VC trust infrastructure. CLR 2.0 extends OB3 — they share the same data model foundation. CTDL can describe the same credentials that OB3 issues, providing the transparency layer. No conflicts with CASE; competency frameworks from CASE can be referenced as badge criteria.",
      "foaf:page": {
        "@id": "https://www.1edtech.org/standards/open-badges"
      },
      "https://firsteducore.org/ontology#authoritativeRepoUrl": {
        "@id": "https://github.com/1EdTech/openbadges-specification"
      },
      "https://firsteducore.org/ontology#implementationGuidance": "Start as a badge verifier/displayer: accept and render OB3 badges from other issuers. Use a managed badge platform (Badgr, Credly, Accredible) for initial issuance to skip infrastructure. Custom issuance requires W3C VC signing infrastructure. Test with 1EdTech conformance suite.",
      "https://firsteducore.org/ontology#commonlyPairedWith": [
        {
          "@id": "https://firsteducore.org/ontology#spec/clr-v2"
        },
        {
          "@id": "https://firsteducore.org/ontology#spec/ctdl"
        },
        {
          "@id": "https://firsteducore.org/ontology#spec/lrw-competency-framework"
        }
      ],
      "https://firsteducore.org/ontology#relatedResource": [
        {
          "@id": "https://firsteducore.org/ontology#spec/clr-v2"
        },
        {
          "@id": "https://firsteducore.org/ontology#spec/ctdl"
        },
        {
          "@id": "https://firsteducore.org/ontology#spec/lrw-competency-framework"
        }
      ],
      "https://firsteducore.org/ontology#burdenRubric": {
        "@id": "https://firsteducore.org/ontology#burden-rubric/open-badges-v3"
      },
      "https://firsteducore.org/ontology#equityConsiderations": {
        "@id": "https://firsteducore.org/ontology#equity/open-badges-v3"
      },
      "https://firsteducore.org/ontology#privacyConsiderations": {
        "@id": "https://firsteducore.org/ontology#privacy/open-badges-v3"
      },
      "https://firsteducore.org/ontology#referenceImplementation": [
        {
          "@id": "https://firsteducore.org/ontology#ref-impl/open-badges-v3/0"
        },
        {
          "@id": "https://firsteducore.org/ontology#ref-impl/open-badges-v3/1"
        }
      ],
      "https://firsteducore.org/ontology#technicalDocLink": [
