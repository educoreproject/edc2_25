      "https://firsteducore.org/ontology#privacyRiskLevel": "medium",
      "https://firsteducore.org/ontology#privacyRiskRationale": "Workforce data includes employment history and credential linkage. Not covered by FERPA but subject to state privacy laws and FCRA in employment screening contexts.",
      "https://firsteducore.org/ontology#piiCategories": [
        {
          "@id": "https://firsteducore.org/ontology#pii-category/BiographicData"
