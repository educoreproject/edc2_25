      "https://firsteducore.org/ontology#cedsElement": [
        "PersonProgramParticipation"
      ],
      "https://firsteducore.org/ontology#alignmentPrivacyRisk": "low"
    },
    {
      "@id": "https://firsteducore.org/ontology#ceds-alignment/lrw-competency-framework/earlyLearning",
