      },
      "https://firsteducore.org/ontology#cedsDomain": {
        "@id": "https://firsteducore.org/ontology#ceds-domain/competencies"
      },
      "https://firsteducore.org/ontology#alignmentStatus": "full",
      "https://firsteducore.org/ontology#notes": "LER credentials carry competency evidence. The standard informatively references CASE and CTDL for competency framework exchange and description.",
      "https://firsteducore.org/ontology#cedsElement": [
        "CompetencyFramework",
        "CompetencyDefinition",
        "CompetencySet",
        "CompetencyDefinition"
      ],
