    },
    {
      "@id": "https://firsteducore.org/ontology#spec/case-v1",
      "@type": "https://firsteducore.org/ontology#Specification",
      "dcterms:identifier": "case-v1",
      "dcterms:title": "Competency & Academic Standards Exchange (CASE) v1.1",
      "dcterms:description": "1EdTech standard for exchanging competency frameworks and academic standards as structured, machine-readable data via a REST/JSON API. Enables systems to publish, discover, and align competency definitions across institutions and platforms.",
      "dcterms:type": "Standard",
      "https://firsteducore.org/ontology#category": "Competency Frameworks",
      "https://firsteducore.org/ontology#owner": "1EdTech Consortium",
      "https://firsteducore.org/ontology#governanceBody": "1EdTech Consortium",
      "dcterms:modified": {
        "@value": "2025-06-01",
        "@type": "xsd:date"
      },
      "https://firsteducore.org/ontology#version": "1.1",
      "https://firsteducore.org/ontology#accessLevel": "open",
      "https://firsteducore.org/ontology#opennessStatus": "open",
      "https://firsteducore.org/ontology#status": "approved",
      "https://firsteducore.org/ontology#aiSummary": "REST/JSON API standard for publishing and exchanging competency frameworks. Use when systems need to share, align, or discover competency definitions across platforms.",
      "https://firsteducore.org/ontology#aiUnlocksSummary": "Enables your product to publish, consume, and align competency frameworks from multiple authorities (state standards, industry frameworks, institutional outcomes). Unlocks cross-institutional competency alignment, dynamic curriculum mapping, and automated standards crosswalking.",
      "https://firsteducore.org/ontology#aiTaxonomy": [
        "competency-exchange",
        "academic-standards",
        "framework-api"
      ],
      "dcterms:subject": [
        "competency",
        "CASE",
        "academic-standards",
        "1EdTech",
        "REST-API",
        "framework-exchange"
      ],
      "https://firsteducore.org/ontology#implementationBurden": "medium",
      "https://firsteducore.org/ontology#implementationBurdenRationale": "Well-defined REST API with JSON responses. Moderate effort for consumer-side; higher for publisher-side where you must model your competency data into CASE format.",
      "https://firsteducore.org/ontology#requiredCapability": [
        "REST API client",
        "JSON parser",
        "Competency data model (for publishers)"
      ],
      "https://firsteducore.org/ontology#knownAdopter": [
        "Achieve (state standards)",
        "OpenSALT community",
        "Multiple US state education agencies",
        "Credential Engine"
      ],
      "https://firsteducore.org/ontology#compatibilityNotes": "CASE is complementary to CTDL (competency definitions vs. credential descriptions) and CLR (competency references in learner records). No overlaps or conflicts. JSON format is simpler than JSON-LD — consider a JSON-LD bridge if integrating with CTDL.",
      "foaf:page": {
        "@id": "https://www.1edtech.org/standards/case"
      },
      "https://firsteducore.org/ontology#implementationGuidance": "Start as a CASE consumer: query existing published frameworks (e.g., state standards) via the REST API. Build a local cache of competency trees. Phase 2: publish your own institutional competency frameworks. Use the CASE Network sandbox for testing.",
      "https://firsteducore.org/ontology#commonlyPairedWith": [
        {
          "@id": "https://firsteducore.org/ontology#spec/lrw-competency-framework"
        },
        {
          "@id": "https://firsteducore.org/ontology#spec/ctdl"
        },
        {
          "@id": "https://firsteducore.org/ontology#spec/clr-v2"
        },
        {
          "@id": "https://firsteducore.org/ontology#spec/open-badges-v3"
        }
      ],
      "https://firsteducore.org/ontology#relatedResource": [
        {
          "@id": "https://firsteducore.org/ontology#spec/lrw-competency-framework"
        },
        {
          "@id": "https://firsteducore.org/ontology#spec/ctdl"
        },
        {
          "@id": "https://firsteducore.org/ontology#spec/clr-v2"
        }
      ],
      "https://firsteducore.org/ontology#burdenRubric": {
        "@id": "https://firsteducore.org/ontology#burden-rubric/case-v1"
      },
      "https://firsteducore.org/ontology#equityConsiderations": {
        "@id": "https://firsteducore.org/ontology#equity/case-v1"
      },
      "https://firsteducore.org/ontology#privacyConsiderations": {
        "@id": "https://firsteducore.org/ontology#privacy/case-v1"
      },
      "https://firsteducore.org/ontology#referenceImplementation": [
        {
          "@id": "https://firsteducore.org/ontology#ref-impl/case-v1/0"
        },
        {
          "@id": "https://firsteducore.org/ontology#ref-impl/case-v1/1"
        }
      ],
      "https://firsteducore.org/ontology#technicalDocLink": [
        {
          "@id": "https://firsteducore.org/ontology#doc-link/case-v1/0"
        },
        {
          "@id": "https://firsteducore.org/ontology#doc-link/case-v1/1"
        }
      ],
      "https://firsteducore.org/ontology#cedsAlignment": [
        {
          "@id": "https://firsteducore.org/ontology#ceds-alignment/case-v1/credentials"
        },
        {
          "@id": "https://firsteducore.org/ontology#ceds-alignment/case-v1/competencies"
        },
        {
          "@id": "https://firsteducore.org/ontology#ceds-alignment/case-v1/workforce"
        },
