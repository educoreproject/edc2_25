<https://firsteducore.org/ontology#spec/ctdl> a educore:Specification ;
    dcterms:identifier "ctdl" ;
    dcterms:title "Credential Transparency Description Language (CTDL)" ;
    dcterms:description "Linked-data vocabulary (JSON-LD/RDF) for describing credentials, organizations, competencies, and their relationships. Maintained by Credential Engine, CTDL powers the Credential Registry and enables machine-readable credential transparency at national scale." ;
    dcterms:type "Standard" ;
    educore:category "Credential Transparency" ;
    educore:owner "Credential Engine" ;
    educore:governanceBody "Credential Engine" ;
    dcterms:modified "2025-08-01"^^xsd:date ;
    educore:version "current" ;
    educore:accessLevel "open" ;
    educore:opennessStatus "open" ;
    educore:status "approved" ;
    foaf:page <https://credreg.net/ctdl/terms> ;
    educore:authoritativeRepoUrl <https://github.com/CredentialEngine/CTDL_Json_Validation_Schema> ;
    educore:aiSummary "Linked-data vocabulary for describing credentials, their requirements, and issuing organizations. Use when publishing or consuming credential metadata for transparency and discovery." ;
    educore:aiUnlocksSummary "Enables your product to describe credentials in a machine-readable, semantically rich format that the Credential Registry and search engines can index. Unlocks credential discovery, comparison, and pathway mapping at national scale — letting learners and employers find and evaluate credentials across thousands of providers." ;
    educore:aiTaxonomy "credential-vocabulary" ;
    educore:aiTaxonomy "linked-data" ;
    educore:aiTaxonomy "transparency" ;
    dcterms:subject "CTDL" ;
    dcterms:subject "credential-transparency" ;
    dcterms:subject "linked-data" ;
    dcterms:subject "JSON-LD" ;
    dcterms:subject "RDF" ;
    dcterms:subject "Credential-Engine" ;
    dcterms:subject "registry" ;
    educore:implementationBurden "medium" ;
    educore:implementationBurdenRationale "JSON-LD/RDF requires familiarity with linked data concepts. Credential Engine provides tools and APIs that reduce the burden. Publishing to the Registry has a structured onboarding process." ;
    educore:implementationGuidance "Begin by exploring the Credential Registry search to understand CTDL data in practice. Map your credentials to CTDL terms using the CTDL Handbook. Use the Credential Engine publisher tool for initial data entry. For programmatic integration, use the Registry API." ;
    educore:requiredCapability "JSON-LD understanding" ;
    educore:requiredCapability "Credential data modeling" ;
    educore:requiredCapability "REST API client (for Registry integration)" ;
    educore:knownAdopter "Credential Engine publisher network (4,000+ organizations)" ;
    educore:knownAdopter "US state longitudinal data systems" ;
    educore:knownAdopter "Lumina Foundation grantees" ;
    educore:knownAdopter "EMSI/Lightcast" ;
    educore:commonlyPairedWith <https://firsteducore.org/ontology#spec/case-v1> ;
    educore:commonlyPairedWith <https://firsteducore.org/ontology#spec/open-badges-v3> ;
    educore:commonlyPairedWith <https://firsteducore.org/ontology#spec/lrw-competency-framework> ;
    educore:relatedResource <https://firsteducore.org/ontology#spec/case-v1> ;
    educore:relatedResource <https://firsteducore.org/ontology#spec/open-badges-v3> ;
    educore:relatedResource <https://firsteducore.org/ontology#spec/lrw-competency-framework> ;
    educore:compatibilityNotes "CTDL is the description/transparency layer while Open Badges and CLR are the issuance/record layers. CTDL describes what a credential IS; OB3/CLR record that a learner HAS one. They are complementary, not competing. CTDL uses JSON-LD; ensure JSON-LD tooling is available if integrating with CASE (plain JSON)." ;
    educore:burdenRubric <https://firsteducore.org/ontology#burden-rubric/ctdl> ;
    educore:equityConsiderations <https://firsteducore.org/ontology#equity/ctdl> ;
    educore:privacyConsiderations <https://firsteducore.org/ontology#privacy/ctdl> ;
    educore:referenceImplementation <https://firsteducore.org/ontology#ref-impl/ctdl/0> ;
    educore:referenceImplementation <https://firsteducore.org/ontology#ref-impl/ctdl/1> ;
    educore:technicalDocLink <https://firsteducore.org/ontology#doc-link/ctdl/0> ;
    educore:technicalDocLink <https://firsteducore.org/ontology#doc-link/ctdl/1> ;
    educore:technicalDocLink <https://firsteducore.org/ontology#doc-link/ctdl/2> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/ctdl/credentials> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/ctdl/competencies> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/ctdl/workforce> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/ctdl/assessments> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/ctdl/learningResources> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/ctdl/k12> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/ctdl/postsecondary> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/ctdl/cte> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/ctdl/adultEd> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/ctdl/earlyLearning> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/ctdl/authN> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/ctdl/implVars> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/ctdl/facilities> .

<https://firsteducore.org/ontology#burden-rubric/ctdl> a educore:BurdenRubric ;
    educore:timeline "4–8 weeks for publishing; 2–4 weeks for consuming Registry data" ;
    educore:engineering <https://firsteducore.org/ontology#burden-dimension/ctdl/engineering> ;
    educore:infrastructure <https://firsteducore.org/ontology#burden-dimension/ctdl/infrastructure> ;
    educore:legal <https://firsteducore.org/ontology#burden-dimension/ctdl/legal> .

<https://firsteducore.org/ontology#burden-dimension/ctdl/engineering> a educore:BurdenDimension ;
    rdfs:label "engineering" ;
    educore:level "moderate" ;
    educore:note "4–8 weeks to model and publish credentials in CTDL. 2–4 weeks for consumer/search integration via Registry API." .

<https://firsteducore.org/ontology#burden-dimension/ctdl/infrastructure> a educore:BurdenDimension ;
    rdfs:label "infrastructure" ;
    educore:level "low" ;
    educore:note "Credential Engine hosts the Registry. Publishers need minimal infrastructure beyond data preparation." .

<https://firsteducore.org/ontology#burden-dimension/ctdl/legal> a educore:BurdenDimension ;
    rdfs:label "legal" ;
    educore:level "low" ;
    educore:note "Open vocabulary. No licensing. Publishing agreement with Credential Engine is straightforward." .

<https://firsteducore.org/ontology#equity/ctdl> a educore:EquityConsideration ;
    educore:level "low-concern" ;
    educore:notes "Vocabulary standard describing credentials. Equity benefit: makes credential information transparent and discoverable to underserved populations. Concern: credential descriptions may omit alternative or non-traditional pathways if not intentionally included." ;
    educore:lifDerived "false"^^xsd:boolean .

<https://firsteducore.org/ontology#privacy/ctdl> a educore:PrivacyConsideration ;
    educore:level "low-concern" ;
    educore:notes "Describes credentials and organizations — no learner PII. Published data is public by design. Organizations publishing to the Registry share institutional information voluntarily." ;
    educore:dataClassification "public" .

<https://firsteducore.org/ontology#ref-impl/ctdl/0> a educore:ReferenceImplementation ;
    rdfs:label "Credential Finder" ;
    foaf:page <https://credentialfinder.org> ;
    dcterms:description "National registry of credentials described in CTDL. Searchable by learners, employers, and systems." .

<https://firsteducore.org/ontology#ref-impl/ctdl/1> a educore:ReferenceImplementation ;
    rdfs:label "CTDL Explorer" ;
    foaf:page <https://credreg.net/ctdl/explorer> ;
    dcterms:description "Interactive browser for CTDL vocabulary terms and relationships." .

<https://firsteducore.org/ontology#doc-link/ctdl/0> a educore:TechnicalDocLink ;
    rdfs:label "CTDL Terms & Vocabulary" ;
    foaf:page <https://credreg.net/ctdl/terms> .

<https://firsteducore.org/ontology#doc-link/ctdl/1> a educore:TechnicalDocLink ;
    rdfs:label "CTDL Handbook" ;
    foaf:page <https://credreg.net/ctdl/handbook> .

<https://firsteducore.org/ontology#doc-link/ctdl/2> a educore:TechnicalDocLink ;
    rdfs:label "Credential Registry API" ;
    foaf:page <https://credreg.net/registry/assistant> .

<https://firsteducore.org/ontology#ceds-alignment/ctdl/credentials> a educore:CedsAlignment ;
    educore:specification <https://firsteducore.org/ontology#spec/ctdl> ;
    educore:cedsDomain <https://firsteducore.org/ontology#ceds-domain/credentials> ;
    educore:alignmentStatus "full" ;
