    dcterms:description "Official conformance testing tool for Open Badges 3.0 implementations." .

<https://firsteducore.org/ontology#ref-impl/open-badges-v3/1> a educore:ReferenceImplementation ;
    rdfs:label "Badgr (open-source)" ;
    foaf:page <https://github.com/concentricsky/badgr-server> ;
    dcterms:description "Open-source badge issuing platform supporting OB3." .

