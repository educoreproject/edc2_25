<https://firsteducore.org/ontology#spec/open-badges-v3> a educore:Specification ;
    dcterms:identifier "open-badges-v3" ;
    dcterms:title "Open Badges 3.0" ;
    dcterms:description "1EdTech standard for issuing, displaying, and verifying digital badges and micro-credentials. Version 3.0 aligns with W3C Verifiable Credentials, enabling cryptographic verification and decentralized trust for achievement recognition." ;
    dcterms:type "Standard" ;
    educore:category "Digital Credentials" ;
    educore:owner "1EdTech Consortium" ;
    educore:governanceBody "1EdTech Consortium" ;
    dcterms:modified "2024-12-01"^^xsd:date ;
    educore:version "3.0" ;
    educore:accessLevel "open" ;
    educore:opennessStatus "open" ;
    educore:status "approved" ;
    foaf:page <https://www.1edtech.org/standards/open-badges> ;
    educore:authoritativeRepoUrl <https://github.com/1EdTech/openbadges-specification> ;
    educore:aiSummary "Standard for issuing and verifying digital badges aligned with W3C VCs. Use when implementing achievement recognition, micro-credentialing, or skill badge systems." ;
    educore:aiUnlocksSummary "Enables your product to issue, display, and verify portable digital badges that learners can share across platforms and with employers. Unlocks micro-credentialing programs, stackable credential pathways, and verifiable achievement sharing — with W3C VC alignment providing cryptographic trust without centralized verification." ;
    educore:aiTaxonomy "digital-badge" ;
    educore:aiTaxonomy "micro-credential" ;
    educore:aiTaxonomy "achievement-verification" ;
    dcterms:subject "open-badges" ;
    dcterms:subject "micro-credentials" ;
    dcterms:subject "digital-badges" ;
    dcterms:subject "1EdTech" ;
    dcterms:subject "verifiable-credentials" ;
    dcterms:subject "JSON-LD" ;
    dcterms:subject "achievement" ;
    educore:implementationBurden "medium" ;
    educore:implementationBurdenRationale "OB3 is well-documented with robust tooling. The W3C VC alignment adds cryptographic complexity but managed services exist. Issuing is more complex than consuming/verifying." ;
    educore:implementationGuidance "Start as a badge verifier/displayer: accept and render OB3 badges from other issuers. Use a managed badge platform (Badgr, Credly, Accredible) for initial issuance to skip infrastructure. Custom issuance requires W3C VC signing infrastructure. Test with 1EdTech conformance suite." ;
    educore:requiredCapability "JSON-LD processing" ;
    educore:requiredCapability "Cryptographic signing (for issuers)" ;
    educore:requiredCapability "Badge display/rendering UI" ;
    educore:requiredCapability "REST API client" ;
    educore:knownAdopter "Credly" ;
    educore:knownAdopter "Badgr/Instructure" ;
    educore:knownAdopter "Accredible" ;
    educore:knownAdopter "Digital Promise" ;
    educore:knownAdopter "Mozilla Foundation (original OB creator)" ;
    educore:commonlyPairedWith <https://firsteducore.org/ontology#spec/clr-v2> ;
    educore:commonlyPairedWith <https://firsteducore.org/ontology#spec/ctdl> ;
    educore:commonlyPairedWith <https://firsteducore.org/ontology#spec/lrw-competency-framework> ;
    educore:relatedResource <https://firsteducore.org/ontology#spec/clr-v2> ;
    educore:relatedResource <https://firsteducore.org/ontology#spec/ctdl> ;
    educore:relatedResource <https://firsteducore.org/ontology#spec/lrw-competency-framework> ;
    educore:compatibilityNotes "OB3 is built on W3C Verifiable Credentials, so it inherits VC trust infrastructure. CLR 2.0 extends OB3 — they share the same data model foundation. CTDL can describe the same credentials that OB3 issues, providing the transparency layer. No conflicts with CASE; competency frameworks from CASE can be referenced as badge criteria." ;
    educore:burdenRubric <https://firsteducore.org/ontology#burden-rubric/open-badges-v3> ;
    educore:equityConsiderations <https://firsteducore.org/ontology#equity/open-badges-v3> ;
    educore:privacyConsiderations <https://firsteducore.org/ontology#privacy/open-badges-v3> ;
    educore:referenceImplementation <https://firsteducore.org/ontology#ref-impl/open-badges-v3/0> ;
    educore:referenceImplementation <https://firsteducore.org/ontology#ref-impl/open-badges-v3/1> ;
    educore:technicalDocLink <https://firsteducore.org/ontology#doc-link/open-badges-v3/0> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/open-badges-v3/credentials> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/open-badges-v3/competencies> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/open-badges-v3/workforce> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/open-badges-v3/assessments> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/open-badges-v3/learningResources> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/open-badges-v3/k12> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/open-badges-v3/postsecondary> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/open-badges-v3/cte> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/open-badges-v3/adultEd> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/open-badges-v3/earlyLearning> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/open-badges-v3/authN> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/open-badges-v3/implVars> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/open-badges-v3/facilities> .

<https://firsteducore.org/ontology#burden-rubric/open-badges-v3> a educore:BurdenRubric ;
    educore:timeline "3–8 weeks depending on issuer vs. consumer role and managed vs. custom implementation" ;
    educore:engineering <https://firsteducore.org/ontology#burden-dimension/open-badges-v3/engineering> ;
    educore:infrastructure <https://firsteducore.org/ontology#burden-dimension/open-badges-v3/infrastructure> ;
    educore:legal <https://firsteducore.org/ontology#burden-dimension/open-badges-v3/legal> .

<https://firsteducore.org/ontology#burden-dimension/open-badges-v3/engineering> a educore:BurdenDimension ;
    rdfs:label "engineering" ;
    educore:level "moderate" ;
    educore:note "4–8 weeks for issuer implementation; 2–3 weeks for verifier/displayer. Managed badge platforms reduce to 1–2 weeks." .

<https://firsteducore.org/ontology#burden-dimension/open-badges-v3/infrastructure> a educore:BurdenDimension ;
    rdfs:label "infrastructure" ;
    educore:level "moderate" ;
    educore:note "Issuers need key management for VC signing. Managed badge platforms (Badgr, Credly) handle infrastructure." .

<https://firsteducore.org/ontology#burden-dimension/open-badges-v3/legal> a educore:BurdenDimension ;
    rdfs:label "legal" ;
    educore:level "low" ;
    educore:note "Open standard. 1EdTech certification available but not required." .

<https://firsteducore.org/ontology#equity/open-badges-v3> a educore:EquityConsideration ;
    educore:level "medium-concern" ;
    educore:notes "Badge UX must be accessible across devices and literacy levels. Visual badge design should meet WCAG standards. Wallet/sharing UX can be a barrier for low-digital-literacy populations. Consider QR code and paper-friendly fallbacks." ;
    educore:lifDerived "true"^^xsd:boolean .

<https://firsteducore.org/ontology#privacy/open-badges-v3> a educore:PrivacyConsideration ;
    educore:level "medium-concern" ;
    educore:notes "Badges contain learner achievement data. Hosted badge verification can create tracking vectors. Learner consent required before public sharing. Revocation mechanisms needed for accuracy. FERPA considerations when badges are issued by educational institutions." ;
    educore:dataClassification "credential-metadata" ;
    educore:regulation "FERPA (educational contexts)" ;
    educore:regulation "GDPR (international)" .

