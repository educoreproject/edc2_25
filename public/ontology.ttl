<https://firsteducore.org/ontology#spec/clr-v2> a educore:Specification ;
    dcterms:identifier "clr-v2" ;
    dcterms:title "Comprehensive Learner Record (CLR) 2.0" ;
    dcterms:description "1EdTech standard for comprehensive, portable learner achievement records. CLR 2.0 extends Open Badges 3.0 to aggregate multiple achievements, competencies, and experiences into a single verifiable record aligned with W3C Verifiable Credentials." ;
    dcterms:type "Standard" ;
    educore:category "Learner Records" ;
    educore:owner "1EdTech Consortium" ;
    educore:governanceBody "1EdTech Consortium" ;
    dcterms:modified "2024-12-01"^^xsd:date ;
    educore:version "2.0" ;
    educore:accessLevel "open" ;
    educore:opennessStatus "open" ;
    educore:status "approved" ;
    foaf:page <https://www.1edtech.org/standards/clr> ;
    educore:aiSummary "Standard for aggregating achievements, badges, and competencies into a comprehensive, verifiable learner record. Use when building learner portfolios, transcript alternatives, or comprehensive credential packages." ;
    educore:aiUnlocksSummary "Enables your product to create comprehensive, portable learner records that aggregate badges, credentials, competencies, and experiences into a single verifiable package. Unlocks holistic learner profiles, transcript modernization, competency-based record-keeping, and cross-institutional record portability — giving learners a complete, verifiable picture of their achievements." ;
    educore:aiTaxonomy "learner-record" ;
    educore:aiTaxonomy "credential-aggregation" ;
    educore:aiTaxonomy "portable-record" ;
    dcterms:subject "CLR" ;
    dcterms:subject "comprehensive-learner-record" ;
    dcterms:subject "learner-record" ;
    dcterms:subject "1EdTech" ;
    dcterms:subject "verifiable-credentials" ;
    dcterms:subject "JSON-LD" ;
    dcterms:subject "portable-record" ;
    educore:implementationBurden "high" ;
    educore:implementationBurdenRationale "CLR 2.0 builds on OB3 and W3C VC, requiring familiarity with both. Aggregating multiple credential types into a coherent record adds data modeling complexity. Managed platforms exist but full custom implementation is significant." ;
    educore:implementationGuidance "Begin by implementing Open Badges 3.0 support first — CLR extends OB3. Start as a CLR consumer: accept and display CLR records from other issuers. Phase 2: aggregate your own badges/achievements into CLR records. Phase 3: implement full issuance with consent management and VC signing. Use 1EdTech conformance suite for validation." ;
    educore:requiredCapability "JSON-LD processing" ;
    educore:requiredCapability "W3C VC signing infrastructure" ;
    educore:requiredCapability "Credential aggregation pipeline" ;
    educore:requiredCapability "Learner consent UI" ;
    educore:requiredCapability "Open Badges 3.0 compatibility" ;
    educore:knownAdopter "Western Governors University" ;
    educore:knownAdopter "AACRAO (Digital Connect)" ;
    educore:knownAdopter "Parchment" ;
    educore:knownAdopter "National Student Clearinghouse" ;
    educore:commonlyPairedWith <https://firsteducore.org/ontology#spec/open-badges-v3> ;
    educore:commonlyPairedWith <https://firsteducore.org/ontology#spec/case-v1> ;
    educore:commonlyPairedWith <https://firsteducore.org/ontology#spec/lrw-competency-framework> ;
    educore:relatedResource <https://firsteducore.org/ontology#spec/open-badges-v3> ;
    educore:relatedResource <https://firsteducore.org/ontology#spec/case-v1> ;
    educore:relatedResource <https://firsteducore.org/ontology#spec/lrw-competency-framework> ;
    educore:compatibilityNotes "CLR 2.0 is a superset of Open Badges 3.0 — every OB3 badge can be included in a CLR. Both are built on W3C Verifiable Credentials. CTDL can describe CLR-issued credentials for registry transparency. CASE competency identifiers can be referenced in CLR achievement criteria. The entire LER stack fits together without conflicts." ;
    educore:burdenRubric <https://firsteducore.org/ontology#burden-rubric/clr-v2> ;
    educore:equityConsiderations <https://firsteducore.org/ontology#equity/clr-v2> ;
    educore:privacyConsiderations <https://firsteducore.org/ontology#privacy/clr-v2> ;
    educore:referenceImplementation <https://firsteducore.org/ontology#ref-impl/clr-v2/0> ;
    educore:referenceImplementation <https://firsteducore.org/ontology#ref-impl/clr-v2/1> ;
    educore:technicalDocLink <https://firsteducore.org/ontology#doc-link/clr-v2/0> ;
    educore:technicalDocLink <https://firsteducore.org/ontology#doc-link/clr-v2/1> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/clr-v2/credentials> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/clr-v2/competencies> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/clr-v2/workforce> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/clr-v2/assessments> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/clr-v2/learningResources> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/clr-v2/k12> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/clr-v2/postsecondary> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/clr-v2/cte> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/clr-v2/adultEd> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/clr-v2/earlyLearning> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/clr-v2/authN> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/clr-v2/implVars> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/clr-v2/facilities> .

<https://firsteducore.org/ontology#burden-rubric/clr-v2> a educore:BurdenRubric ;
    educore:timeline "3–6 months for full implementation; 6–8 weeks for consumer-only mode" ;
    educore:engineering <https://firsteducore.org/ontology#burden-dimension/clr-v2/engineering> ;
    educore:infrastructure <https://firsteducore.org/ontology#burden-dimension/clr-v2/infrastructure> ;
    educore:legal <https://firsteducore.org/ontology#burden-dimension/clr-v2/legal> .

<https://firsteducore.org/ontology#burden-dimension/clr-v2/engineering> a educore:BurdenDimension ;
    rdfs:label "engineering" ;
    educore:level "high" ;
    educore:note "8–16 weeks for full issuer implementation. 4–6 weeks for consumer/viewer. Managed platforms reduce effort." .

<https://firsteducore.org/ontology#burden-dimension/clr-v2/infrastructure> a educore:BurdenDimension ;
    rdfs:label "infrastructure" ;
    educore:level "high" ;
    educore:note "Requires credential aggregation pipeline, W3C VC signing infrastructure, and learner consent management." .

<https://firsteducore.org/ontology#burden-dimension/clr-v2/legal> a educore:BurdenDimension ;
    rdfs:label "legal" ;
    educore:level "moderate" ;
    educore:note "Learner data aggregation requires consent management. FERPA compliance for educational institutions. 1EdTech certification available." .

<https://firsteducore.org/ontology#equity/clr-v2> a educore:EquityConsideration ;
    educore:level "medium-concern" ;
    educore:notes "CLR aggregation complexity can create a digital divide. Learners with fewer institutional touchpoints may have thinner CLR records, potentially disadvantaging them. Ensure CLR viewers present non-traditional achievements equitably. Wallet UX accessibility is critical." ;
    educore:lifDerived "true"^^xsd:boolean .

<https://firsteducore.org/ontology#privacy/clr-v2> a educore:PrivacyConsideration ;
    educore:level "high-concern" ;
    educore:notes "CLR records aggregate comprehensive learner data including achievements, competencies, and institutional history. FERPA compliance mandatory for educational issuers. Learner consent required for each achievement included. Selective disclosure mechanisms (from W3C VC) should be implemented to let learners share only relevant portions." ;
    educore:dataClassification "PII / educational-record" ;
    educore:regulation "FERPA" ;
    educore:regulation "COPPA (under-13 contexts)" ;
    educore:regulation "GDPR (international)" ;
    educore:regulation "state privacy laws" .

<https://firsteducore.org/ontology#ref-impl/clr-v2/0> a educore:ReferenceImplementation ;
    rdfs:label "1EdTech CLR Conformance Suite" ;
    foaf:page <https://www.1edtech.org/spec/clr/v2p0/cert> ;
    dcterms:description "Official conformance testing for CLR 2.0 implementations." .

