@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix educore: <https://firsteducore.org/ontology#> .

<https://firsteducore.org/ontology> a owl:Ontology ;
    rdfs:label "EDU Reference Library Ontology" ;
    rdfs:comment "Machine-readable catalog of LER ecosystem specifications, implementation metadata, and CEDS alignment." ;
    owl:versionInfo "1.0" .

educore:Specification a owl:Class ;
    rdfs:label "Specification" ;
    rdfs:comment "A specification or standard in the EDU reference library" .

educore:BurdenRubric a owl:Class ;
    rdfs:label "BurdenRubric" ;
    rdfs:comment "Implementation burden breakdown for a specification" .

educore:BurdenDimension a owl:Class ;
    rdfs:label "BurdenDimension" ;
    rdfs:comment "A single dimension of implementation burden (engineering, infrastructure, or legal)" .

educore:EquityConsideration a owl:Class ;
    rdfs:label "EquityConsideration" ;
    rdfs:comment "Equity and accessibility assessment for a specification" .

educore:PrivacyConsideration a owl:Class ;
    rdfs:label "PrivacyConsideration" ;
    rdfs:comment "Privacy and security assessment for a specification" .

educore:ReferenceImplementation a owl:Class ;
    rdfs:label "ReferenceImplementation" ;
    rdfs:comment "A reference implementation or tool for a specification" .

educore:TechnicalDocLink a owl:Class ;
    rdfs:label "TechnicalDocLink" ;
    rdfs:comment "A link to technical documentation" .

educore:CedsAlignment a owl:Class ;
    rdfs:label "CedsAlignment" ;
    rdfs:comment "Alignment assessment between a specification and a CEDS domain" .

educore:CedsDomain a owl:Class ;
    rdfs:label "CedsDomain" ;
    rdfs:comment "A CEDS (Common Education Data Standards) ontology domain" .

<https://firsteducore.org/ontology#ceds-domain/credentials> a educore:CedsDomain ;
    rdfs:label "Credentials" ;
    dcterms:identifier "credentials" .

<https://firsteducore.org/ontology#ceds-domain/competencies> a educore:CedsDomain ;
    rdfs:label "Competencies" ;
    dcterms:identifier "competencies" .

<https://firsteducore.org/ontology#ceds-domain/workforce> a educore:CedsDomain ;
    rdfs:label "Workforce" ;
    dcterms:identifier "workforce" .

<https://firsteducore.org/ontology#ceds-domain/assessments> a educore:CedsDomain ;
    rdfs:label "Assessments" ;
    dcterms:identifier "assessments" .

<https://firsteducore.org/ontology#ceds-domain/learningResources> a educore:CedsDomain ;
    rdfs:label "Learning Resources" ;
    dcterms:identifier "learningResources" .

<https://firsteducore.org/ontology#ceds-domain/k12> a educore:CedsDomain ;
    rdfs:label "K–12" ;
    dcterms:identifier "k12" .

<https://firsteducore.org/ontology#ceds-domain/postsecondary> a educore:CedsDomain ;
    rdfs:label "Postsecondary" ;
    dcterms:identifier "postsecondary" .

<https://firsteducore.org/ontology#ceds-domain/cte> a educore:CedsDomain ;
    rdfs:label "Career & Technical" ;
    dcterms:identifier "cte" .

<https://firsteducore.org/ontology#ceds-domain/adultEd> a educore:CedsDomain ;
    rdfs:label "Adult Education" ;
    dcterms:identifier "adultEd" .

<https://firsteducore.org/ontology#ceds-domain/earlyLearning> a educore:CedsDomain ;
    rdfs:label "Early Learning" ;
    dcterms:identifier "earlyLearning" .

<https://firsteducore.org/ontology#ceds-domain/authN> a educore:CedsDomain ;
    rdfs:label "Auth & Authorization" ;
    dcterms:identifier "authN" .

<https://firsteducore.org/ontology#ceds-domain/implVars> a educore:CedsDomain ;
    rdfs:label "Implementation Variables" ;
    dcterms:identifier "implVars" .

<https://firsteducore.org/ontology#ceds-domain/facilities> a educore:CedsDomain ;
    rdfs:label "Facilities" ;
    dcterms:identifier "facilities" .

<https://firsteducore.org/ontology#spec/lrw-competency-framework> a educore:Specification ;
    dcterms:identifier "lrw-competency-framework" ;
    dcterms:title "IEEE P1484.2 LER Ecosystem Standard" ;
    dcterms:description "IEEE P1484.2 Recommended Practices for Learning and Employment Record (LER) Ecosystems are intended to help system architects and engineers design and deploy systems that leverage shared standards and technologies to support ecosystem-scale issuing, holding, and presenting verifiable credentials for education, skills-based hiring, and career advancement." ;
    dcterms:type "Standard" ;
    educore:category "Learner Records" ;
    educore:owner "IEEE Computer Society" ;
    educore:governanceBody "IEEE Computer Society / Learning Technology Standards Committee (C/LTSC)" ;
    dcterms:modified "2024-08-23"^^xsd:date ;
    educore:version "2024" ;
    educore:accessLevel "open" ;
    educore:opennessStatus "open" ;
    educore:status "approved" ;
    foaf:page <https://sagroups.ieee.org/1484-2/> ;
    educore:aiSummary "IEEE recommended practice defining the architecture and roles for LER ecosystems. Use as the overarching blueprint when building systems for issuing, holding, and verifying education and employment credentials." ;
    educore:aiUnlocksSummary "Provides the ecosystem-level architecture for your product to participate in LER credential exchange. Defines the roles (Awarder, Holder, Reviewer, Wallet, Registry) and trust model that connect issuers, learners, and employers — positioning your platform within a standards-based, interoperable credential ecosystem for skills-based hiring." ;
    educore:aiTaxonomy "ler-ecosystem" ;
    educore:aiTaxonomy "credential-architecture" ;
    educore:aiTaxonomy "skills-based-hiring" ;
    dcterms:subject "LER" ;
    dcterms:subject "IEEE" ;
    dcterms:subject "verifiable-credentials" ;
    dcterms:subject "ecosystem" ;
    dcterms:subject "workforce" ;
    dcterms:subject "skills-based-hiring" ;
    dcterms:subject "career-advancement" ;
    dcterms:subject "credential-engine" ;
    dcterms:subject "1EdTech" ;
    educore:implementationBurden "medium" ;
    educore:implementationBurdenRationale "The standard is a recommended practice (architectural blueprint), not a wire protocol. Implementation burden depends on which ecosystem role(s) your system fulfills. Leverages W3C VC and DID as normative foundations." ;
    educore:implementationGuidance "Start by identifying which LER ecosystem role(s) your system will fulfill: Awarder (issuer), Holder (wallet/learner), Reviewer (verifier), or Registry (governance). Implement W3C VC and DID support as the normative foundation. Use Open Badges 3.0 or CLR 2.0 as the credential format. Align trust model to the standard's five recommended components." ;
    educore:requiredCapability "W3C Verifiable Credentials support" ;
    educore:requiredCapability "W3C DID infrastructure" ;
    educore:requiredCapability "Digital wallet integration (for Holder role)" ;
    educore:requiredCapability "Credential registry access (recommended)" ;
    educore:knownAdopter "T3 Innovation Network pilot partners" ;
    educore:knownAdopter "US Chamber of Commerce Foundation" ;
    educore:knownAdopter "Credential Engine" ;
    educore:knownAdopter "AACRAO" ;
    educore:commonlyPairedWith <https://firsteducore.org/ontology#spec/case-v1> ;
    educore:commonlyPairedWith <https://firsteducore.org/ontology#spec/ctdl> ;
    educore:commonlyPairedWith <https://firsteducore.org/ontology#spec/clr-v2> ;
    educore:commonlyPairedWith <https://firsteducore.org/ontology#spec/open-badges-v3> ;
    educore:relatedResource <https://firsteducore.org/ontology#spec/case-v1> ;
    educore:relatedResource <https://firsteducore.org/ontology#spec/ctdl> ;
    educore:relatedResource <https://firsteducore.org/ontology#spec/open-badges-v3> ;
    educore:relatedResource <https://firsteducore.org/ontology#spec/clr-v2> ;
    educore:compatibilityNotes "IEEE 1484.2-2024 is the ecosystem architecture standard — it defines roles and trust models. CASE, CTDL, Open Badges, and CLR are the implementation standards that fulfill specific roles within the LER ecosystem. The standard normatively references W3C VCs and DIDs, and informatively references CEDS, CASE, CTDL, CLR, and Credential Registry." ;
    educore:burdenRubric <https://firsteducore.org/ontology#burden-rubric/lrw-competency-framework> ;
    educore:equityConsiderations <https://firsteducore.org/ontology#equity/lrw-competency-framework> ;
    educore:privacyConsiderations <https://firsteducore.org/ontology#privacy/lrw-competency-framework> ;
    educore:referenceImplementation <https://firsteducore.org/ontology#ref-impl/lrw-competency-framework/0> ;
    educore:technicalDocLink <https://firsteducore.org/ontology#doc-link/lrw-competency-framework/0> ;
    educore:technicalDocLink <https://firsteducore.org/ontology#doc-link/lrw-competency-framework/1> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/lrw-competency-framework/credentials> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/lrw-competency-framework/competencies> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/lrw-competency-framework/workforce> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/lrw-competency-framework/assessments> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/lrw-competency-framework/learningResources> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/lrw-competency-framework/k12> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/lrw-competency-framework/postsecondary> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/lrw-competency-framework/cte> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/lrw-competency-framework/adultEd> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/lrw-competency-framework/earlyLearning> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/lrw-competency-framework/authN> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/lrw-competency-framework/implVars> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/lrw-competency-framework/facilities> .

<https://firsteducore.org/ontology#burden-rubric/lrw-competency-framework> a educore:BurdenRubric ;
    educore:timeline "4–12 weeks depending on ecosystem role and existing infrastructure" ;
    educore:engineering <https://firsteducore.org/ontology#burden-dimension/lrw-competency-framework/engineering> ;
    educore:infrastructure <https://firsteducore.org/ontology#burden-dimension/lrw-competency-framework/infrastructure> ;
    educore:legal <https://firsteducore.org/ontology#burden-dimension/lrw-competency-framework/legal> .

<https://firsteducore.org/ontology#burden-dimension/lrw-competency-framework/engineering> a educore:BurdenDimension ;
    rdfs:label "engineering" ;
    educore:level "moderate" ;
    educore:note "4–8 weeks to align an existing system to the LER architecture. Longer if building W3C VC infrastructure from scratch." .

<https://firsteducore.org/ontology#burden-dimension/lrw-competency-framework/infrastructure> a educore:BurdenDimension ;
    rdfs:label "infrastructure" ;
    educore:level "moderate" ;
    educore:note "Requires W3C VC-compatible credential infrastructure. Digital wallet integration needed for Holder role. Registry infrastructure for governance role." .

<https://firsteducore.org/ontology#burden-dimension/lrw-competency-framework/legal> a educore:BurdenDimension ;
    rdfs:label "legal" ;
    educore:level "low" ;
    educore:note "IEEE standard is publicly referenced. No licensing fees for conformance. Data sharing agreements needed for multi-party ecosystems." .

<https://firsteducore.org/ontology#equity/lrw-competency-framework> a educore:EquityConsideration ;
    educore:level "medium-concern" ;
    educore:notes "The standard acknowledges the need for equitable access to credential infrastructure. Digital wallet requirements may create barriers for learners without smartphones or stable internet. Alternative presentation methods should be supported." ;
    educore:lifDerived "false"^^xsd:boolean .

<https://firsteducore.org/ontology#privacy/lrw-competency-framework> a educore:PrivacyConsideration ;
    educore:level "medium-concern" ;
    educore:notes "LER ecosystems involve PII in verifiable credentials. The standard recommends selective disclosure and privacy-preserving verification. Implementers must address FERPA compliance for education records and consent management for credential sharing." ;
    educore:dataClassification "architectural-standard" ;
    educore:regulation "FERPA" ;
    educore:regulation "state privacy laws" .

<https://firsteducore.org/ontology#ref-impl/lrw-competency-framework/0> a educore:ReferenceImplementation ;
    rdfs:label "IEEE 1484.2-2024 Standard (IEEE Store)" ;
    foaf:page <https://standards.ieee.org/ieee/1484.2/11406/> ;
    dcterms:description "Official published standard document." .

<https://firsteducore.org/ontology#doc-link/lrw-competency-framework/0> a educore:TechnicalDocLink ;
    rdfs:label "Project Website" ;
    foaf:page <https://sagroups.ieee.org/1484-2/> .

<https://firsteducore.org/ontology#doc-link/lrw-competency-framework/1> a educore:TechnicalDocLink ;
    rdfs:label "IEEE Standard (purchase)" ;
    foaf:page <https://standards.ieee.org/ieee/1484.2/11406/> .

<https://firsteducore.org/ontology#ceds-alignment/lrw-competency-framework/credentials> a educore:CedsAlignment ;
    educore:specification <https://firsteducore.org/ontology#spec/lrw-competency-framework> ;
    educore:cedsDomain <https://firsteducore.org/ontology#ceds-domain/credentials> ;
    educore:alignmentStatus "full" ;
    educore:notes "Core focus of the LER standard. Defines ecosystem roles (Awarder, Holder, Reviewer) for credential issuance and verification built on W3C VCs." ;
    educore:cedsElement "Credential" ;
    educore:cedsElement "CredentialType" ;
    educore:cedsElement "CredentialAwardedBy" ;
    educore:cedsElement "CredentialAwardStatus" ;
    educore:cedsElement "CredentialVerification" .

<https://firsteducore.org/ontology#ceds-alignment/lrw-competency-framework/competencies> a educore:CedsAlignment ;
    educore:specification <https://firsteducore.org/ontology#spec/lrw-competency-framework> ;
    educore:cedsDomain <https://firsteducore.org/ontology#ceds-domain/competencies> ;
    educore:alignmentStatus "full" ;
    educore:notes "LER credentials carry competency evidence. The standard informatively references CASE and CTDL for competency framework exchange and description." ;
    educore:cedsElement "CompetencyFramework" ;
    educore:cedsElement "CompetencyDefinition" ;
    educore:cedsElement "CompetencySet" ;
    educore:cedsElement "LearningStandard" .

<https://firsteducore.org/ontology#ceds-alignment/lrw-competency-framework/workforce> a educore:CedsAlignment ;
    educore:specification <https://firsteducore.org/ontology#spec/lrw-competency-framework> ;
    educore:cedsDomain <https://firsteducore.org/ontology#ceds-domain/workforce> ;
    educore:alignmentStatus "full" ;
    educore:notes "Skills-based hiring and career advancement are primary use cases. LER Talent Marketplace role directly addresses workforce credential matching." ;
    educore:cedsElement "WorkforceProgram" ;
    educore:cedsElement "EmploymentRecord" ;
    educore:cedsElement "OccupationalClassification" ;
    educore:cedsElement "SkillRequirement" .

<https://firsteducore.org/ontology#ceds-alignment/lrw-competency-framework/assessments> a educore:CedsAlignment ;
    educore:specification <https://firsteducore.org/ontology#spec/lrw-competency-framework> ;
    educore:cedsDomain <https://firsteducore.org/ontology#ceds-domain/assessments> ;
    educore:alignmentStatus "partial" ;
    educore:notes "LER credentials can carry assessment outcomes as verifiable claims. The standard does not model assessment event structure." ;
    educore:gapNotes "CEDS Assessments domain models full assessment lifecycle; LER standard focuses on credential-level outcomes." ;
    educore:cedsElement "AssessmentResult" .

<https://firsteducore.org/ontology#ceds-alignment/lrw-competency-framework/learningResources> a educore:CedsAlignment ;
    educore:specification <https://firsteducore.org/ontology#spec/lrw-competency-framework> ;
    educore:cedsDomain <https://firsteducore.org/ontology#ceds-domain/learningResources> ;
    educore:alignmentStatus "partial" ;
    educore:notes "LER credentials can reference learning experiences. The standard does not model learning resource metadata at CEDS level of detail." ;
    educore:cedsElement "LearningResource" .

<https://firsteducore.org/ontology#ceds-alignment/lrw-competency-framework/k12> a educore:CedsAlignment ;
    educore:specification <https://firsteducore.org/ontology#spec/lrw-competency-framework> ;
    educore:cedsDomain <https://firsteducore.org/ontology#ceds-domain/k12> ;
    educore:alignmentStatus "partial" ;
    educore:notes "K–12 credentials (diplomas, course completions) are valid LER use cases. Standard is education-level agnostic." ;
    educore:gapNotes "CEDS K12 includes detailed enrollment, attendance, and discipline data beyond LER scope." ;
    educore:cedsElement "K12StudentAcademicRecord" .

<https://firsteducore.org/ontology#ceds-alignment/lrw-competency-framework/postsecondary> a educore:CedsAlignment ;
    educore:specification <https://firsteducore.org/ontology#spec/lrw-competency-framework> ;
    educore:cedsDomain <https://firsteducore.org/ontology#ceds-domain/postsecondary> ;
    educore:alignmentStatus "full" ;
    educore:notes "Postsecondary credential issuance and verification is a primary LER use case. Strong alignment with CEDS postsecondary credential elements." ;
    educore:cedsElement "PsDegreeOrCertificate" ;
    educore:cedsElement "PsStudentAcademicRecord" ;
    educore:cedsElement "PsProgram" .

<https://firsteducore.org/ontology#ceds-alignment/lrw-competency-framework/cte> a educore:CedsAlignment ;
    educore:specification <https://firsteducore.org/ontology#spec/lrw-competency-framework> ;
    educore:cedsDomain <https://firsteducore.org/ontology#ceds-domain/cte> ;
    educore:alignmentStatus "full" ;
    educore:notes "CTE and industry credential portability are core LER objectives. The standard directly addresses skills-based hiring that CTE programs feed into." ;
    educore:cedsElement "CTEProgram" ;
    educore:cedsElement "CTEOccupationalCluster" ;
    educore:cedsElement "CTEIndustryAlignment" .

<https://firsteducore.org/ontology#ceds-alignment/lrw-competency-framework/adultEd> a educore:CedsAlignment ;
    educore:specification <https://firsteducore.org/ontology#spec/lrw-competency-framework> ;
    educore:cedsDomain <https://firsteducore.org/ontology#ceds-domain/adultEd> ;
    educore:alignmentStatus "partial" ;
    educore:notes "Adult education credentials (GED, workforce certificates) are valid LER use cases. No adult-education-specific modeling in the standard." ;
    educore:cedsElement "AdultEducationProgram" .

<https://firsteducore.org/ontology#ceds-alignment/lrw-competency-framework/earlyLearning> a educore:CedsAlignment ;
    educore:specification <https://firsteducore.org/ontology#spec/lrw-competency-framework> ;
    educore:cedsDomain <https://firsteducore.org/ontology#ceds-domain/earlyLearning> ;
    educore:alignmentStatus "gap" ;
    educore:notes "LER standard is not designed for early childhood contexts." ;
    educore:gapNotes "CEDS Early Learning developmental domains not represented." .

<https://firsteducore.org/ontology#ceds-alignment/lrw-competency-framework/authN> a educore:CedsAlignment ;
    educore:specification <https://firsteducore.org/ontology#spec/lrw-competency-framework> ;
    educore:cedsDomain <https://firsteducore.org/ontology#ceds-domain/authN> ;
    educore:alignmentStatus "full" ;
    educore:notes "LER standard normatively requires W3C DIDs for identity. Defines trust, verification, and wallet roles that directly address authentication and authorization." ;
    educore:cedsElement "PersonIdentifier" ;
    educore:cedsElement "AuthorizationDocument" .

<https://firsteducore.org/ontology#ceds-alignment/lrw-competency-framework/implVars> a educore:CedsAlignment ;
    educore:specification <https://firsteducore.org/ontology#spec/lrw-competency-framework> ;
    educore:cedsDomain <https://firsteducore.org/ontology#ceds-domain/implVars> ;
    educore:alignmentStatus "partial" ;
    educore:notes "LER Registry role provides organizational identity and governance catalogs. Partial alignment with CEDS Implementation Variables." ;
    educore:cedsElement "ImplementationStatus" ;
    educore:cedsElement "OrganizationIdentificationSystem" .

<https://firsteducore.org/ontology#ceds-alignment/lrw-competency-framework/facilities> a educore:CedsAlignment ;
    educore:specification <https://firsteducore.org/ontology#spec/lrw-competency-framework> ;
    educore:cedsDomain <https://firsteducore.org/ontology#ceds-domain/facilities> ;
    educore:alignmentStatus "gap" ;
    educore:notes "No overlap." .

<https://firsteducore.org/ontology#spec/case-v1> a educore:Specification ;
    dcterms:identifier "case-v1" ;
    dcterms:title "Competency & Academic Standards Exchange (CASE) v1.1" ;
    dcterms:description "1EdTech standard for exchanging competency frameworks and academic standards as structured, machine-readable data via a REST/JSON API. Enables systems to publish, discover, and align competency definitions across institutions and platforms." ;
    dcterms:type "Standard" ;
    educore:category "Competency Frameworks" ;
    educore:owner "1EdTech Consortium" ;
    educore:governanceBody "1EdTech Consortium" ;
    dcterms:modified "2025-06-01"^^xsd:date ;
    educore:version "1.1" ;
    educore:accessLevel "open" ;
    educore:opennessStatus "open" ;
    educore:status "approved" ;
    foaf:page <https://www.1edtech.org/standards/case> ;
    educore:aiSummary "REST/JSON API standard for publishing and exchanging competency frameworks. Use when systems need to share, align, or discover competency definitions across platforms." ;
    educore:aiUnlocksSummary "Enables your product to publish, consume, and align competency frameworks from multiple authorities (state standards, industry frameworks, institutional outcomes). Unlocks cross-institutional competency alignment, dynamic curriculum mapping, and automated standards crosswalking." ;
    educore:aiTaxonomy "competency-exchange" ;
    educore:aiTaxonomy "academic-standards" ;
    educore:aiTaxonomy "framework-api" ;
    dcterms:subject "competency" ;
    dcterms:subject "CASE" ;
    dcterms:subject "academic-standards" ;
    dcterms:subject "1EdTech" ;
    dcterms:subject "REST-API" ;
    dcterms:subject "framework-exchange" ;
    educore:implementationBurden "medium" ;
    educore:implementationBurdenRationale "Well-defined REST API with JSON responses. Moderate effort for consumer-side; higher for publisher-side where you must model your competency data into CASE format." ;
    educore:implementationGuidance "Start as a CASE consumer: query existing published frameworks (e.g., state standards) via the REST API. Build a local cache of competency trees. Phase 2: publish your own institutional competency frameworks. Use the CASE Network sandbox for testing." ;
    educore:requiredCapability "REST API client" ;
    educore:requiredCapability "JSON parser" ;
    educore:requiredCapability "Competency data model (for publishers)" ;
    educore:knownAdopter "Achieve (state standards)" ;
    educore:knownAdopter "OpenSALT community" ;
    educore:knownAdopter "Multiple US state education agencies" ;
    educore:knownAdopter "Credential Engine" ;
    educore:commonlyPairedWith <https://firsteducore.org/ontology#spec/lrw-competency-framework> ;
    educore:commonlyPairedWith <https://firsteducore.org/ontology#spec/ctdl> ;
    educore:commonlyPairedWith <https://firsteducore.org/ontology#spec/clr-v2> ;
    educore:relatedResource <https://firsteducore.org/ontology#spec/lrw-competency-framework> ;
    educore:relatedResource <https://firsteducore.org/ontology#spec/ctdl> ;
    educore:relatedResource <https://firsteducore.org/ontology#spec/clr-v2> ;
    educore:compatibilityNotes "CASE is complementary to CTDL (competency definitions vs. credential descriptions) and CLR (competency references in learner records). No overlaps or conflicts. JSON format is simpler than JSON-LD — consider a JSON-LD bridge if integrating with CTDL." ;
    educore:burdenRubric <https://firsteducore.org/ontology#burden-rubric/case-v1> ;
    educore:equityConsiderations <https://firsteducore.org/ontology#equity/case-v1> ;
    educore:privacyConsiderations <https://firsteducore.org/ontology#privacy/case-v1> ;
    educore:referenceImplementation <https://firsteducore.org/ontology#ref-impl/case-v1/0> ;
    educore:referenceImplementation <https://firsteducore.org/ontology#ref-impl/case-v1/1> ;
    educore:technicalDocLink <https://firsteducore.org/ontology#doc-link/case-v1/0> ;
    educore:technicalDocLink <https://firsteducore.org/ontology#doc-link/case-v1/1> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/case-v1/credentials> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/case-v1/competencies> ;
    educore:cedsAlignment <https://firsteducore.org/ontology#ceds-alignment/case-v1/workforce> ;
